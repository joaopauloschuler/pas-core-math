const
{$I inc_64/log1p_const_64.inc}
  cLog1pEpsFastSmall: Tb64u64 = (u:$3BF6000000000000); // 0x1.6p-64
  cLog1pEpsFastMid:   Tb64u64 = (u:$3CB9400000000000); // 0x1.94p-52
  cLog1pEpsFastBig:   Tb64u64 = (u:$3BEA000000000000); // 0x1.ap-65
  cLog1pL1Per:        Tb64u64 = (u:$3FE62E42FEFA4000); // 0x1.62e42fefa4p-1
  cLog1pL0Per:        Tb64u64 = (u:QWord($BD48432A1B0E2634)); // -0x1.8432a1b0e2634p-43
  cLog1pInvLog2Scl:   Tb64u64 = (u:$40F71547652B82FE); // 0x1.71547652b82fep+16
  // refine je-dependent coefficients
  cLog1pR_L2:         Tb64u64 = (u:$3FE62E42FEFA4000); // 0x1.62e42fefa4p-1
  cLog1pR_L1:         Tb64u64 = (u:QWord($BD48432A1B0E2800)); // -0x1.8432a1b0e28p-43
  cLog1pR_L0:         Tb64u64 = (u:$3A8CC01F97B57A08); // 0x1.cc01f97b57a08p-87

// ---------- Local helpers (C-grouping; not normalized) -----------------------

// muldd_log1p: (cl*xh + ch*xl) + fma(ch,xh,-ahhh)  — matches C log1p muldd
function Log1pMuldd(xh, xl, ch, cl: Double; out l: Double): Double; inline;
var ahhh: Double;
begin
  ahhh := ch * xh;
  l := (cl * xh + ch * xl) + pcr_fma(ch, xh, -ahhh);
  Result := ahhh;
end;

// mulddd_log1p: cl*x + fma(ch,x,-ahhh)
function Log1pMulddd(x, ch, cl: Double; out l: Double): Double; inline;
var ahhh: Double;
begin
  ahhh := ch * x;
  l := cl * x + pcr_fma(ch, x, -ahhh);
  Result := ahhh;
end;

// twosum: full Knuth two-sum (no |xh|>=|ch| precondition)
function Log1pTwosum(xh, ch: Double; out l: Double): Double; inline;
var s, d: Double;
begin
  s := xh + ch;
  d := s - xh;
  l := (ch - d) + (xh + (d - s));
  Result := s;
end;

// fastsum: (xh,xl)+(yh,yl) using fasttwosum on heads
function Log1pFastsum(xh, xl, yh, yl: Double; out e: Double): Double; inline;
var sl, sh: Double;
begin
  pcr_fasttwosum(sh, sl, xh, yh);
  e := (xl + yl) + sl;
  Result := sh;
end;

// sum: (xh,xl)+(ch,cl) using twosum on heads
function Log1pSum(xh, xl, ch, cl: Double; out l: Double): Double; inline;
var sl, sh: Double;
begin
  sh := Log1pTwosum(xh, ch, sl);
  l := (xl + cl) + sl;
  Result := sh;
end;

// ----------------------------------------------------------------------------
// Slow refine path. Pascal port of as_log1p_refine.
function Log1pRefine(x, a: Double): Double;
var
  ix, t, dt, tu: Tb64u64;
  ax: UInt64;
  ln22, ln21, ln20: Double;
  x2h, x2l, x3h, x3l, sh, sl: Double;
  i, i1, i2, i3, i4, je: Int64;
  L0, L1, L2: Double;
  t12, t34, th, tl, dh, dl, sh2, sl2: Double;
  xh, xl, ddh, ddl: Double;
  ch_, cl_, th_, tl_: Double;
  w: Tb64u64;
begin
  ix.f := x;
  ax := ix.u shl 1;

  if ax < UInt64($7ea0000000000000) then
  begin
    if ax < UInt64($7940000000000000) then
    begin
      if ax = 0 then begin Result := x; Exit; end;
      Result := pcr_fma(pcr_fabs(x), Double(-1.0) * Double(5.5511151231257827e-17), x);
      // 0x1p-54 = 5.5511151231257827e-17
      Exit;
    end;
    x2h := x * x;
    x2l := pcr_fma(x, x, -x2h);
    x3h := Log1pMulddd(x, x2h, x2l, x3l);
    sl := x * ((cLog1pCzl_0.f + x * cLog1pCzl_1.f) + x2h * (cLog1pCzl_2.f + x * cLog1pCzl_3.f));

    // Seeded polyddd: n=5, x scalar. ch = fasttwosum(c[4][0], sl, &sl); cl = c[4][1] + sl
    pcr_fasttwosum(ch_, sl, cLog1pCz_4_0.f, sl);
    cl_ := cLog1pCz_4_1.f + sl;
    // Pillar A: unrolled k = 3, 2, 1, 0 (fixed trip count over cLog1pCz).
    ch_ := Log1pMulddd(x, ch_, cl_, cl_);
    pcr_fasttwosum(th_, tl_, cLog1pCz_3_0.f, ch_);
    cl_ := (cLog1pCz_3_1.f + cl_) + tl_;
    ch_ := th_;
    ch_ := Log1pMulddd(x, ch_, cl_, cl_);
    pcr_fasttwosum(th_, tl_, cLog1pCz_2_0.f, ch_);
    cl_ := (cLog1pCz_2_1.f + cl_) + tl_;
    ch_ := th_;
    ch_ := Log1pMulddd(x, ch_, cl_, cl_);
    pcr_fasttwosum(th_, tl_, cLog1pCz_1_0.f, ch_);
    cl_ := (cLog1pCz_1_1.f + cl_) + tl_;
    ch_ := th_;
    ch_ := Log1pMulddd(x, ch_, cl_, cl_);
    pcr_fasttwosum(th_, tl_, cLog1pCz_0_0.f, ch_);
    cl_ := (cLog1pCz_0_1.f + cl_) + tl_;
    ch_ := th_;
    sl := cl_;
    sh := ch_;

    sh := Log1pMuldd(sh, sl, x3h, x3l, sl);
    x2h := x2h * Double(-0.5);
    x2l := x2l * Double(-0.5);
    ln22 := x;
    ln21 := Log1pFastsum(x2h, x2l, sh, sl, ln20);
  end
  else
  begin
    i := Trunc(pcr_roundeven(a * cLog1pInvLog2Scl.f));
    i := i + 34952;
    i1 := SarInt64(i, 12) and $F;
    i2 := SarInt64(i, 8) and $F;
    i3 := SarInt64(i, 4) and $F;
    i4 :=  i         and $F;
    je :=  SarInt64(i, 16);

    L0 := (cLog1pLn[0, i1, 0].f + cLog1pLn[1, i2, 0].f) + (cLog1pLn[2, i3, 0].f + cLog1pLn[3, i4, 0].f);
    L1 := (cLog1pLn[0, i1, 1].f + cLog1pLn[1, i2, 1].f) + (cLog1pLn[2, i3, 1].f + cLog1pLn[3, i4, 1].f);
    L2 := (cLog1pLn[0, i1, 2].f + cLog1pLn[1, i2, 2].f) + (cLog1pLn[2, i3, 2].f + cLog1pLn[3, i4, 2].f);

    if (Int64(ix.u) < Int64($4690000000000000)) and (ix.u < UInt64($bfe0000000000000)) then
    begin
      t.f := Log1pTwosum(Double(1.0), x, dt.f);
      if (dt.u shl 1) = 0 then dt.u := 0;
    end
    else
    begin
      if Int64(ix.u) >= Int64($4690000000000000) then
        t.f := x
      else
        t.f := Double(1.0) + x;
      dt.u := 0;
    end;
    t.u := UInt64(Int64(t.u) - (je shl 52));

    t12 := cLog1pRt[0, i1].f * cLog1pRt[1, i2].f;
    t34 := cLog1pRt[2, i3].f * cLog1pRt[3, i4].f;
    th := t12 * t34;
    tl := pcr_fma(t12, t34, -th);
    dh := th * t.f;
    dl := pcr_fma(th, t.f, -dh);
    sh2 := tl * t.f;
    sl2 := pcr_fma(tl, t.f, -sh2);

    pcr_fasttwosum(xh, xl, dh - Double(1.0), dl);
    xh := Log1pFastsum(xh, xl, sh2, sl2, xl);

    if dt.u <> 0 then
    begin
      dt.u := UInt64(Int64(dt.u) - (je shl 52));
      ddh := th * dt.f;
      ddl := pcr_fma(th, dt.f, -ddh) + tl * dt.f;
      xh := Log1pFastsum(xh, xl, ddh, ddl, xl);
    end;

    sl := xh * ((cLog1pCl_0.f + xh * cLog1pCl_1.f) + (xh * xh) * (cLog1pCl_2.f + xh * cLog1pCl_3.f));

    // Seeded polydd: n=5, ch=fasttwosum(cy[4][0], sl, &sl); cl = cy[4][1] + sl
    pcr_fasttwosum(ch_, sl, cLog1pCy_4_0.f, sl);
    cl_ := cLog1pCy_4_1.f + sl;
    // Pillar A: unrolled k = 3, 2, 1, 0 (fixed trip count over cLog1pCy).
    ch_ := Log1pMuldd(xh, xl, ch_, cl_, cl_);
    pcr_fasttwosum(th_, tl_, cLog1pCy_3_0.f, ch_);
    cl_ := (cLog1pCy_3_1.f + cl_) + tl_;
    ch_ := th_;
    ch_ := Log1pMuldd(xh, xl, ch_, cl_, cl_);
    pcr_fasttwosum(th_, tl_, cLog1pCy_2_0.f, ch_);
    cl_ := (cLog1pCy_2_1.f + cl_) + tl_;
    ch_ := th_;
    ch_ := Log1pMuldd(xh, xl, ch_, cl_, cl_);
    pcr_fasttwosum(th_, tl_, cLog1pCy_1_0.f, ch_);
    cl_ := (cLog1pCy_1_1.f + cl_) + tl_;
    ch_ := th_;
    ch_ := Log1pMuldd(xh, xl, ch_, cl_, cl_);
    pcr_fasttwosum(th_, tl_, cLog1pCy_0_0.f, ch_);
    cl_ := (cLog1pCy_0_1.f + cl_) + tl_;
    ch_ := th_;
    sl := cl_;
    sh := ch_;

    sh := Log1pMuldd(xh, xl, sh, sl, sl);

    if je <> 0 then
    begin
      ln22 := cLog1pR_L2.f * je;
      ln21 := cLog1pR_L1.f * je;
      ln20 := cLog1pR_L0.f * je;
      ln22 := ln22 + L2;
      ln21 := Log1pFastsum(ln21, ln20, L1, L0, ln20);
    end
    else
    begin
      ln22 := L2;
      ln21 := L1;
      ln20 := L0;
    end;
    ln21 := Log1pSum(ln21, ln20, sh, sl, ln20);
  end;

  pcr_fasttwosum(ln22, ln21, ln22, ln21);
  pcr_fasttwosum(ln21, ln20, ln21, ln20);

  tu.f := ln21;
  if (tu.u and (UInt64($FFFFFFFFFFFFFFFF) shr 12)) = 0 then
  begin
    w.f := ln20;
    if ((w.u xor tu.u) shr 63) <> 0 then
      tu.u := tu.u - 1
    else
      tu.u := tu.u + 1;
    ln21 := tu.f;
  end;
  Result := ln22 + ln21;
end;

function pcr_log1p(x: Double): Double;
var
  ix, t, dt, rs: Tb64u64;
  ax: UInt64;
  ln1, ln0, eps, lb, ub: Double;
  x2, x3, x4, hx, f: Double;
  j, je: Int64;
  j1: Int64;
  eoff: UInt64;
  dh, dl, xh, xl, x2_local: Double;
  L1, L0: Double;
  scl: Double;
begin
  ix.f := x;
  ax := ix.u shl 1;

  if ax < UInt64($7f60000000000000) then  // |x| < 0.0625
  begin
    if ax < UInt64($7940000000000000) then  // |x| < 2^-53
    begin
      if ax = 0 then begin Result := x; Exit; end;
      // fma(|x|, -2^-54, x); 0x1p-54 = 5.551115123125783e-17
      Result := pcr_fma(pcr_fabs(x), Double(-5.5511151231257827e-17), x);
      Exit;
    end;
    x2 := x * x;
    if ax < UInt64($7e60000000000000) then  // |x| < 2^-12
    begin
      ln1 := x;
      eps := cLog1pEpsFastSmall.f * x;
      if ax < UInt64($7d43360000000000) then  // |x| < 0x1.19bp-21
      begin
        ln0 := x2 * (cLog1pSmall1_0.f + x * cLog1pSmall1_1.f);
      end
      else
      begin
        ln0 := x2 * ((cLog1pSmall2_0.f + x * cLog1pSmall2_1.f)
                   + x2 * (cLog1pSmall2_2.f + x * cLog1pSmall2_3.f));
      end;
    end
    else
    begin
      x3 := x2 * x;
      x4 := x2 * x2;
      hx := Double(-0.5) * x;
      ln1 := pcr_fma(hx, x, x);
      ln0 := pcr_fma(hx, x, x - ln1);
      f := ((cLog1pMedium_0.f + x * cLog1pMedium_1.f) + x2 * (cLog1pMedium_2.f + x * cLog1pMedium_3.f))
         + x4 * (((cLog1pMedium_4.f + x * cLog1pMedium_5.f) + x2 * (cLog1pMedium_6.f + x * cLog1pMedium_7.f))
              + x4 * ((cLog1pMedium_8.f + x * cLog1pMedium_9.f) + x2 * (cLog1pMedium_10.f + x * cLog1pMedium_11.f)));
      ln0 := ln0 + x3 * f;
      eps := x3 * cLog1pEpsFastMid.f;
    end;
  end
  else  // |x| >= 0.0625
  begin
    if (Int64(ix.u) < Int64($4340000000000000)) and (ix.u < UInt64($bff0000000000000)) then
    begin
      pcr_fasttwosum(t.f, dt.f, Double(1.0), x);
    end
    else
    begin
      if ix.u < UInt64($4690000000000000) then
      begin
        t.f := x; dt.f := Double(1.0);
      end
      else
      begin
        if ix.u < UInt64($7ff0000000000000) then
        begin
          t.f := x; dt.f := Double(0.0);
        end
        else
        begin
          if ax > UInt64($ffe0000000000000) then begin Result := x + x; Exit; end;
          if ix.u = UInt64($7ff0000000000000) then begin Result := x; Exit; end;
          if ix.u = UInt64($bff0000000000000) then begin Result := Double(-1.0) / Double(0.0); Exit; end;
          Result := Double(0.0) / Double(0.0); Exit;
        end;
      end;
    end;

    j := Int64(t.u) - Int64($3fe6a00000000000);
    j1 := SarInt64(j, 52 - 6) and $3F;
    je := SarInt64(j, 52);
    eoff := UInt64(je) shl 52;
    rs.f := cLog1pRf[j1].f;
    if je < 1022 then
    begin
      rs.u := rs.u - eoff;
    end
    else
    begin
      rs.u := UInt64(Int64(rs.u) - (Int64(1021) shl 52));
      // sc[je-1022]: 0x1p-1, 0x1p-2, 0x1p-3
      case (je - 1022) of
        0: scl := Double(0.5);
        1: scl := Double(0.25);
      else
        scl := Double(0.125);
      end;
      t.f := t.f * scl;
      dt.f := dt.f * scl;
    end;
    dh := rs.f * t.f;
    dl := pcr_fma(rs.f, t.f, -dh) + rs.f * dt.f;
    pcr_fasttwosum(xh, xl, dh - Double(1.0), dl);
    x2_local := xh * xh;
    xl := xl + x2_local * ((cLog1pBig_0.f + xh * cLog1pBig_1.f)
                         + x2_local * ((cLog1pBig_2.f + xh * cLog1pBig_3.f)
                                     + x2_local * (cLog1pBig_4.f + xh * cLog1pBig_5.f)));
    L1 := cLog1pL1Per.f * je;
    L0 := cLog1pL0Per.f * je;
    ln1 := cLog1pLf[j1, 1].f + L1;
    ln0 := cLog1pLf[j1, 0].f + L0;
    ln1 := Log1pFastsum(ln1, ln0, xh, xl, ln0);
    eps := cLog1pEpsFastBig.f;
  end;

  lb := ln1 + (ln0 - eps);
  ub := ln1 + (ln0 + eps);
  if lb <> ub then begin Result := Log1pRefine(x, lb); Exit; end;
  Result := lb;
end;
