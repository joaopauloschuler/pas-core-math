const
  cTGOverThr:     Tb64u64 = (u:$4060573FAE561F64);  // 0x1.573fae561f648p+7
  cTGSubMin:      Tb64u64 = (u:$0010000000000000);  // 0x1p-1022
  cTGSubMinNeg:   Tb64u64 = (u:QWord($8010000000000000));  // -0x1p-1022
  cTGOvflPos:     Tb64u64 = (u:$7FE8000000000000);  // 0x1.fp1023
  cTGTinyAxThr:   UInt64  = $71E0000000000000;      // |x| < 2^-112 boundary (ax)
  cTGSpecPow1024H:Tb64u64 = (u:$7FEFFFFFFFFFFFFF);  // 0x1.fffffffffffffp+1023
  cTGSpecPow1024L:Tb64u64 = (u:$5C90000000000000);  // 0x1p+970
  cTGPow_m1024:   Tb64u64 = (u:$0004000000000000);  // 2^-1024 (subnormal)
  cTGPiH:         Tb64u64 = (u:$400921FB54442D18);
  cTGPiL:         Tb64u64 = (u:$3CA1A62633145C07);
  cTGLogTblH:     Tb64u64 = (u:$3FE62E42FEF80000);  // 0x1.62e42fef8p-1
  cTGLogTblL:     Tb64u64 = (u:$3DB1CF79ABC9E3B4);  // 0x1.1cf79abc9e3b4p-36
  cTGExpLn2H:     Tb64u64 = (u:$40971547652B82FE);  // 0x1.71547652b82fep+10
  cTGExpLn2L:     Tb64u64 = (u:$3D1777D0FFDA0D24);  // 0x1.777d0ffda0d24p-46
  cTGSpltOff:     Tb64u64 = (u:$41A8000000000000);  // 0x1.8p27
  cTGScaleP518:   Tb64u64 = (u:$6050000000000000);  // 2^518
  cTGScaleM500:   Tb64u64 = (u:$20B0000000000000);  // 2^-500
  cTGEps54:       Tb64u64 = (u:$3C90000000000000);  // 2^-54
  cTGEps107:      Tb64u64 = (u:$3940000000000000);  // 2^-107
  cTGEps53:       Tb64u64 = (u:$3CA0000000000000);  // 2^-53
  cTGEpsAcc:      Tb64u64 = (u:$398E000000000000);  // 0x1.ep-103
