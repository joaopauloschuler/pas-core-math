// ---------------------------------------------------------------------------
// Local primitives matching tgamma.c grouping exactly.
// ---------------------------------------------------------------------------

procedure TGFastTwoSum(out s, e: Double; x, y: Double); inline;
var ss: Double;
begin
  ss := x + y;
  e  := y - (ss - x);
  s  := ss;
end;

procedure TGFastSum(out h, l: Double; xh, xl, yh, yl: Double); inline;
var sl: Double;
begin
  TGFastTwoSum(h, sl, xh, yh);
  l := (xl + yl) + sl;
end;

procedure TGSumDD(out h, l: Double; xh, xl, yh, yl: Double); inline;
var sl: Double;
begin
  if Abs(xh) > Abs(yh) then TGFastTwoSum(h, sl, xh, yh)
  else                       TGFastTwoSum(h, sl, yh, xh);
  l := (xl + yl) + sl;
end;

procedure TGTwoSum(out h, e: Double; x, y: Double); inline;
begin
  if Abs(x) > Abs(y) then TGFastTwoSum(h, e, x, y)
  else                    TGFastTwoSum(h, e, y, x);
end;

// muldd (no renormalization)
function TGMul(xh, xl, ch, cl: Double; out l: Double): Double; inline;
var ahhh: Double;
begin
  ahhh := ch * xh;
  l    := (ch * xl + cl * xh) + pcr_fma(ch, xh, -ahhh);
  Result := ahhh;
end;

function TGMul3(xh, xl, yh, yl: Double; out l: Double): Double; inline;
var chv, cl1, tl0, tl1, cl2, cl3, s, e: Double;
begin
  chv := xh * yh;
  cl1 := pcr_fma(xh, yh, -chv);
  tl0 := xl * yl;
  tl1 := tl0 + xh * yl;
  cl2 := tl1 + xl * yh;
  cl3 := cl1 + cl2;
  TGFastTwoSum(s, e, chv, cl3);
  l := e;
  Result := s;
end;

function TGMulD(x, ch, cl: Double; out l: Double): Double; inline;
var ahhh: Double;
begin
  ahhh := ch * x;
  l    := cl * x + pcr_fma(ch, x, -ahhh);
  Result := ahhh;
end;

// polydd seeded: c flat array of size 2*n: c[2i]=c[i][0], c[2i+1]=c[i][1].
function TGPolyDD(xh, xl: Double; n: Int32;
                  const c: array of Tb64u64; var l: Double): Double;
var i: Int32; chv, cl, sh, sl: Double;
begin
  i := n - 1;
  TGFastTwoSum(chv, cl, c[2*i].f, l);
  cl := cl + c[2*i + 1].f;
  Dec(i);
  while i >= 0 do
  begin
    chv := TGMul(xh, xl, chv, cl, cl);
    TGFastTwoSum(sh, sl, c[2*i].f, chv);
    cl  := (c[2*i + 1].f + cl) + sl;
    chv := sh;
    Dec(i);
  end;
  l := cl;
  Result := chv;
end;

function TGPolyDDD(x: Double; n: Int32;
                   const c: array of Tb64u64; var l: Double): Double;
var i: Int32; chv, cl, sh, sl: Double;
begin
  i := n - 1;
  TGFastTwoSum(chv, cl, c[2*i].f, l);
  cl := cl + c[2*i + 1].f;
  Dec(i);
  while i >= 0 do
  begin
    chv := TGMulD(x, chv, cl, cl);
    TGSumDD(sh, sl, c[2*i].f, c[2*i + 1].f, chv, cl);
    chv := sh; cl := sl;
    Dec(i);
  end;
  l := cl;
  Result := chv;
end;

procedure TGSplt(out xh, xl: Double; x: Double); inline;
var t, off: Double;
begin
  off := cTGSpltOff.f;
  t := x + off;
  xh := t - off;
  xl := x - xh;
end;

procedure TGSprod(out z0, l1v, l2v: Double; x, x0, x1, x2: Double); inline;
var z0t, z0l, z1, z2, e: Double;
begin
  z0t := x * x0;
  z0l := pcr_fma(x, x0, -z0t);
  z1  := x * x1;
  z2  := x * x2 + pcr_fma(x, x1, -z1);
  TGSplt(z0t, e, z0t);
  TGFastTwoSum(e, z0l, e, z0l);
  TGTwoSum(l1v, e, e, z1);
  l2v := e + z0l + z2;
  z0  := z0t;
end;

// poly3 — accurate-path multi-coeff polynomial evaluator
function TGPoly3(d: Double; imax: Int32; const ch: array of Tb64u64;
                 jmax: Int32; const cl: array of Tb64u64; out ol: Double): Double;
var
  t0, t1, t2, s0, s1, s2, fh, fl, sh, sl: Double;
  i: Int32;
begin
  t0 := 1.0; t1 := 0.0; t2 := 0.0;
  s0 := ch[0].f; s1 := 0.0; s2 := 0.0;
  for i := 1 to imax - 1 do
  begin
    TGSprod(t0, t1, t2, d, t0, t1, t2);
    s0 := s0 + t0 * ch[i].f;
    fh := TGMulD(ch[i].f, t1, t2, fl);
    TGSumDD(sh, sl, s1, s2, fh, fl);
    s1 := sh; s2 := sl;
  end;
  fl := 0.0;
  fh := TGPolyDDD(d, jmax, cl, fl);
  TGSumDD(sh, sl, s1, s2, fh, fl);
  s1 := sh; s2 := sl;
  TGFastTwoSum(s0, s1, s0, s1);
  TGFastTwoSum(s1, s2, s1, s2);
  ol := s1;
  Result := s0;
end;

// Floor that works for huge doubles (Math.Floor would overflow Int64).
function TGFloor(x: Double): Double; inline;
var ix: Double;
begin
  ix := System.Int(x);
  if (x < 0.0) and (ix <> x) then ix := ix - 1.0;
  Result := ix;
end;

procedure TGRaiseUnderflow; inline;
{$IFDEF AVX2}
var f: DWord;
begin
  f := pcr_get_mxcsr;
  pcr_set_mxcsr(f or $10);
end;
{$ELSE}
begin
end;
{$ENDIF}

// ---------------------------------------------------------------------------
// Helper to flatten a [N][2] table into a flat array for TGPolyDD/DDD.
// ---------------------------------------------------------------------------
type TTGFlatArr = array of Tb64u64;

function TGFlat(const t: array of Tb64u64): TTGFlatArr;
var i: Int32;
begin
  Result := nil;
  SetLength(Result, Length(t));
  for i := 0 to High(t) do Result[i] := t[i];
end;

// ---------------------------------------------------------------------------
// as_logd — fast log via 32x32 bipartite table lookup.
// ---------------------------------------------------------------------------
function TGLogd(x: Double; out l: Double): Double;
var
  t: Tb64u64;
  ex, ee, i1, i2: Int32;
  ed, r, o, dxl, dxh, dx, dx2, f, lt, lh, ll: Double;
  iIdx: UInt64;
  dRaw, j: Int64;
begin
  t.f := x;
  ex := Int32(t.u shr 52);
  ee := ex - $3FF;
  t.u := t.u and (UInt64($FFFFFFFFFFFFFFFF) shr 12);
  ed := ee;
  iIdx := t.u shr (52 - 5);
  dRaw := Int64(t.u and (UInt64($FFFFFFFFFFFFFFFF) shr 17));
  j := SarInt64(
        Int64(t.u + (UInt64(cTGLogB[iIdx].c0) shl 33))
          + Int64(cTGLogB[iIdx].c1) * SarInt64(dRaw, 16),
        52 - 10);
  t.u := t.u or (UInt64($3FF) shl 52);
  i1 := Int32(j shr 5);
  i2 := Int32(j and $1F);
  r  := cTGLogR1[i1].f * cTGLogR2[i2].f;
  o  := r * t.f;
  dxl := pcr_fma(r, t.f, -o);
  dxh := o - 1.0;
  dx  := pcr_fma(r, t.f, -1.0);
  dx2 := dx * dx;
  f := dx2 * ((cTGLogC[0].f + dx*cTGLogC[1].f) + dx2*(cTGLogC[2].f + dx*cTGLogC[3].f));
  lt := (cTGLogL1[i1, 1].f + cTGLogL2[i2, 1].f) + ed * cTGLogTblH.f;
  lh := lt + dxh;
  ll := (lt - lh) + dxh;
  ll := ll + ((cTGLogL1[i1, 0].f + cTGLogL2[i2, 0].f) + cTGLogTblL.f * ed) + dxl;
  ll := ll + f;
  l  := ll;
  Result := lh;
end;

// ---------------------------------------------------------------------------
// as_sinpid: sinpi(0.5+x') flavour using 64-entry sin/cos table
// ---------------------------------------------------------------------------
function TGSinpid(x: Double; out l: Double): Double;
var
  ix, d, d2, P, Q: Double;
  ky, kx: Int32;
  shv, slv, chv, cl: Double;
  qh, ql, th, tl, ph, pl: Double;
  xs, outl: Double;
begin
  xs := Abs(x - 0.5) * 128.0;
  ix := pcr_roundeven(xs);
  d  := ix - xs;
  d2 := d * d;
  ky := Int32(Trunc(ix));
  kx := 64 - ky;
  shv := cTGSt[kx, 1].f; slv := cTGSt[kx, 0].f;
  chv := cTGSt[ky, 1].f; cl  := cTGSt[ky, 0].f;

  P := d2 * (cTGSinpC[1].f + d2 * (cTGSinpC[2].f + d2 * cTGSinpC[3].f));
  Q := d2 * (cTGSinpS[1].f + d2 * (cTGSinpS[2].f + d2 * cTGSinpS[3].f));

  TGFastTwoSum(qh, ql, cTGSinpS[0].f, Q); ql := ql + cTGSinpS0.f;
  chv := TGMul(qh, ql, chv, cl, cl);

  TGFastTwoSum(th, tl, cTGSinpC[0].f, P); tl := tl + cTGSinpC0.f;
  th := TGMulD(d, th, tl, tl);

  ph := TGMul(th, tl, shv, slv, pl);
  TGFastSum(chv, cl, chv, cl, ph, pl);
  chv := TGMulD(d, chv, cl, cl);
  TGFastSum(shv, outl, shv, slv, chv, cl);
  l := outl;
  Result := shv;
end;

// ---------------------------------------------------------------------------
// as_expd — exp(xh+xl), returns rh, *l, *e. The "*e" is the binary exponent
// shift to apply to the resulting double-double.
// ---------------------------------------------------------------------------
function TGExpd(x: Double; var l: Double; out e: Int32): Double;
var
  xh, xl, ix: Double;
  k, i0, i1: Int32;
  rh, rl, fh, fl, el: Double;
  cFlat: TTGFlatArr;
begin
  xh := x; xl := l;
  xh := TGMul(xh, xl, cTGExpLn2H.f, cTGExpLn2L.f, xl);
  ix := pcr_roundeven(xh);
  TGFastTwoSum(xh, xl, xh - ix, xl);
  k  := Int32(Trunc(ix));
  i0 := (k shr 5) and $1F;
  i1 := k and $1F;
  e  := SarLongInt(k, 10);
  rh := TGMul(cTGExpE0[i0, 1].f, cTGExpE0[i0, 0].f,
              cTGExpE1[i1, 1].f, cTGExpE1[i1, 0].f, rl);
  cFlat := TGFlat(cTGExpC[0]); // includes all 5*2 entries
  // cFlat[0..1] = c[0], cFlat[2..3] = c[1], etc.  But TGFlat takes a flat 1-D
  // array; we need to flatten the 2D table. Use direct access instead.
  // fl = xh * polyd(xh, 4, c+1)
  fl := xh * (cTGExpC[1, 0].f + xh * (cTGExpC[2, 0].f + xh * (cTGExpC[3, 0].f + xh * cTGExpC[4, 0].f)));
  // fh = polydd(xh, xl, 1, c, &fl)  — only c[0] entry; seeded by fl
  // Inline polydd for n=1: chv = fasttwosum(c[0][0], fl); cl = e + c[0][1]; loop 0 times.
  TGFastTwoSum(fh, fl, cTGExpC[0, 0].f, fl);
  fl := fl + cTGExpC[0, 1].f;
  fh := TGMul(xh, xl, fh, fl, fl);
  TGFastTwoSum(fh, el, 1.0, fh); fl := fl + el;
  rh := TGMul(rh, rl, fh, fl, rl);
  l  := rl;
  Result := rh;
end;

// ---------------------------------------------------------------------------
// as_lgamma_asym — Stirling series log-gamma. Input xh (+xl), result lh, xl.
// ---------------------------------------------------------------------------
function TGLgammaAsym(xh: Double; var xl: Double): Double;
var
  zh, dz, zl, ll, lh, z2h, z2l, fh, fl, x2, x4: Double;
  q0, q2, q4, q6, q8: Double;
  bArr: array of Tb64u64;
begin
  zh := 1.0 / xh;
  dz := xl * zh;
  zl := (pcr_fma(zh, -xh, 1.0) - dz) * zh;
  lh := TGLogd(xh, ll);
  ll := ll + dz;
  lh := TGMul(xh - 0.5, xl, lh - 1.0, ll, ll);
  z2h := TGMul(zh, zl, zh, zl, z2l);
  x2 := z2h * z2h;
  if xh > 11.5 then
  begin
    TGFastSum(lh, ll, lh, ll, cTGLgBig[0, 0].f, cTGLgBig[0, 1].f);
    q0 := cTGLgBig[2, 0].f + z2h * cTGLgBig[3, 0].f;
    q2 := cTGLgBig[4, 0].f + z2h * cTGLgBig[5, 0].f;
    q4 := cTGLgBig[6, 0].f + z2h * cTGLgBig[7, 0].f;
    fl := z2h * (q0 + x2 * (q2 + x2 * q4));
    SetLength(bArr, 2);
    bArr[0] := cTGLgBig[1, 0]; bArr[1] := cTGLgBig[1, 1];
    fh := TGPolyDD(z2h, z2l, 1, bArr, fl);
  end
  else
  begin
    TGFastSum(lh, ll, lh, ll, cTGLgSml[0, 0].f, cTGLgSml[0, 1].f);
    x4 := x2 * x2;
    q0 := cTGLgSml[3, 0].f + z2h * cTGLgSml[4, 0].f;
    q2 := cTGLgSml[5, 0].f + z2h * cTGLgSml[6, 0].f;
    q4 := cTGLgSml[7, 0].f + z2h * cTGLgSml[8, 0].f;
    q6 := cTGLgSml[9, 0].f + z2h * cTGLgSml[10, 0].f;
    q8 := cTGLgSml[11, 0].f + z2h * cTGLgSml[12, 0].f;
    q4 := q4 + x2 * (q6 + x2 * q8);
    q0 := q0 + x2 * q2;
    q0 := q0 + x4 * q4;
    fl := z2h * q0;
    SetLength(bArr, 4);
    bArr[0] := cTGLgSml[1, 0]; bArr[1] := cTGLgSml[1, 1];
    bArr[2] := cTGLgSml[2, 0]; bArr[3] := cTGLgSml[2, 1];
    fh := TGPolyDD(z2h, z2l, 2, bArr, fl);
  end;
  fh := TGMul(zh, zl, fh, fl, fl);
  TGFastSum(lh, ll, lh, ll, fh, fl);
  xl := ll;
  Result := lh;
end;

// ---------------------------------------------------------------------------
// Database lookup
// ---------------------------------------------------------------------------
function TGDatabase(x, f: Double): Double;
var a, b, m: Int32;
begin
  a := 0; b := High(cTGDb); m := (a + b) shr 1;
  while a <= b do
  begin
    if cTGDb[m, 0].f < x then a := m + 1
    else if cTGDb[m, 0].f = x then
    begin
      f := cTGDb[m, 1].f + cTGDb[m, 2].f;
      Break;
    end
    else b := m - 1;
    m := (a + b) shr 1;
  end;
  Result := f;
end;

// ---------------------------------------------------------------------------
// as_tgamma_accurate — slow path
// ---------------------------------------------------------------------------
function TGAccurate(x: Double): Double;
var
  cFlat: TTGFlatArr;
  i, branchIdx, jm, eoff, jSign: Int32;
  x2, x4, c0v, c4v, cl, ch, fh, fl, fll, dh, et: Double;
  ix, dval: Double;
  ic: Int32;
  wh, wl, xph, xpl, lTmp: Double;
  rh, rl: Double;
  crr, op, om: Double;
  eps, ub, lb: Double;
  res: Tb64u64;
  re: Int64;
  chFlat: TTGFlatArr;
begin
  // ---- Path A: |x| < 0.25 -------------------------------------------------
  if Abs(x) < 0.25 then
  begin
    SetLength(cFlat, 28*2);
    for i := 0 to 27 do
    begin
      cFlat[2*i]   := cTGAccSmallCc[i, 0];
      cFlat[2*i+1] := cTGAccSmallCc[i, 1];
    end;
    x2 := x * x; x4 := x2 * x2;
    c0v := cTGAccSmallC[0].f + x*cTGAccSmallC[1].f
           + x2*(cTGAccSmallC[2].f + x*cTGAccSmallC[3].f);
    c4v := cTGAccSmallC[4].f + x*cTGAccSmallC[5].f
           + x2*(cTGAccSmallC[6].f + x*cTGAccSmallC[7].f);
    c0v := c0v + x4*c4v;
    cl := x * c0v;
    ch := TGPolyDDD(x, 28, cFlat, cl);
    fh := 1.0 / x;
    dh := pcr_fma(fh, -x, 1.0);
    fl := dh * fh;
    fll := pcr_fma(fl, -x, dh) * fh;
    TGSumDD(fl, fll, fl, fll, ch, cl);
    TGTwoSum(fl, fll, fl, fll);
    TGFastTwoSum(fh, fl, fh, fl);
    TGFastTwoSum(fl, fll, fl, fll);
    TGFastTwoSum(et, et, fh, 2.0 * fl);  // discard sum, only need et
    // (Actually C: fasttwosum(fh, 2*fl, &et) — return value unused, just et.)
    if et = 0.0 then
    begin
      // Same-sign test via signbit comparison
      if ((fl >= 0.0) = (fll >= 0.0)) then
        fl := fl * (1.0 + cTGEps50.f)
      else
        fl := fl * (1.0 - cTGEps50.f);
    end;
    Result := fh + fl;
    Exit;
  end;

  // ---- Path B: 0.25 <= |x| -----------------------------------------------
  ix := TGFloor(x);
  dval := 2.0 * (x - (ix + 0.5));
  ic := Int32(Trunc(ix));
  if ic > 159 then begin branchIdx := 0; jm := 160 - ic; eoff := 942; end
  else if ic > 127 then begin branchIdx := 1; jm := 128 - ic; eoff := 713; end
  else if ic > 95  then begin branchIdx := 2; jm := 96  - ic; eoff := 495; end
  else if ic > 63  then begin branchIdx := 3; jm := 64  - ic; eoff := 293; end
  else if ic > 31  then begin branchIdx := 4; jm := 32  - ic; eoff := 115; end
  else if ic > 25  then begin branchIdx := 5; jm := 26  - ic; eoff := 86;  end
  else if ic > 15  then begin branchIdx := 6; jm := 16  - ic; eoff := 42;  end
  else if ic > 7   then begin branchIdx := 7; jm := 8   - ic; eoff := 14;  end
  else                  begin branchIdx := 8; jm := 4   - ic; eoff := 3;   end;

  // Dispatch poly3 evaluation per branch
  case branchIdx of
    0: begin
         chFlat := TGFlat(cTGAcc0Ch);
         SetLength(cFlat, Length(cTGAcc0Cl)*2);
         for i := 0 to High(cTGAcc0Cl) do
           begin cFlat[2*i] := cTGAcc0Cl[i, 0]; cFlat[2*i+1] := cTGAcc0Cl[i, 1]; end;
         fh := TGPoly3(dval, Length(cTGAcc0Ch), chFlat, Length(cTGAcc0Cl), cFlat, fl);
       end;
    1: begin
         chFlat := TGFlat(cTGAcc1Ch);
         SetLength(cFlat, Length(cTGAcc1Cl)*2);
         for i := 0 to High(cTGAcc1Cl) do
           begin cFlat[2*i] := cTGAcc1Cl[i, 0]; cFlat[2*i+1] := cTGAcc1Cl[i, 1]; end;
         fh := TGPoly3(dval, Length(cTGAcc1Ch), chFlat, Length(cTGAcc1Cl), cFlat, fl);
       end;
    2: begin
         chFlat := TGFlat(cTGAcc2Ch);
         SetLength(cFlat, Length(cTGAcc2Cl)*2);
         for i := 0 to High(cTGAcc2Cl) do
           begin cFlat[2*i] := cTGAcc2Cl[i, 0]; cFlat[2*i+1] := cTGAcc2Cl[i, 1]; end;
         fh := TGPoly3(dval, Length(cTGAcc2Ch), chFlat, Length(cTGAcc2Cl), cFlat, fl);
       end;
    3: begin
         chFlat := TGFlat(cTGAcc3Ch);
         SetLength(cFlat, Length(cTGAcc3Cl)*2);
         for i := 0 to High(cTGAcc3Cl) do
           begin cFlat[2*i] := cTGAcc3Cl[i, 0]; cFlat[2*i+1] := cTGAcc3Cl[i, 1]; end;
         fh := TGPoly3(dval, Length(cTGAcc3Ch), chFlat, Length(cTGAcc3Cl), cFlat, fl);
       end;
    4: begin
         chFlat := TGFlat(cTGAcc4Ch);
         SetLength(cFlat, Length(cTGAcc4Cl)*2);
         for i := 0 to High(cTGAcc4Cl) do
           begin cFlat[2*i] := cTGAcc4Cl[i, 0]; cFlat[2*i+1] := cTGAcc4Cl[i, 1]; end;
         fh := TGPoly3(dval, Length(cTGAcc4Ch), chFlat, Length(cTGAcc4Cl), cFlat, fl);
       end;
    5: begin
         chFlat := TGFlat(cTGAcc5Ch);
         SetLength(cFlat, Length(cTGAcc5Cl)*2);
         for i := 0 to High(cTGAcc5Cl) do
           begin cFlat[2*i] := cTGAcc5Cl[i, 0]; cFlat[2*i+1] := cTGAcc5Cl[i, 1]; end;
         fh := TGPoly3(dval, Length(cTGAcc5Ch), chFlat, Length(cTGAcc5Cl), cFlat, fl);
       end;
    6: begin
         chFlat := TGFlat(cTGAcc6Ch);
         SetLength(cFlat, Length(cTGAcc6Cl)*2);
         for i := 0 to High(cTGAcc6Cl) do
           begin cFlat[2*i] := cTGAcc6Cl[i, 0]; cFlat[2*i+1] := cTGAcc6Cl[i, 1]; end;
         fh := TGPoly3(dval, Length(cTGAcc6Ch), chFlat, Length(cTGAcc6Cl), cFlat, fl);
       end;
    7: begin
         chFlat := TGFlat(cTGAcc7Ch);
         SetLength(cFlat, Length(cTGAcc7Cl)*2);
         for i := 0 to High(cTGAcc7Cl) do
           begin cFlat[2*i] := cTGAcc7Cl[i, 0]; cFlat[2*i+1] := cTGAcc7Cl[i, 1]; end;
         fh := TGPoly3(dval, Length(cTGAcc7Ch), chFlat, Length(cTGAcc7Cl), cFlat, fl);
       end;
    else
       begin
         chFlat := TGFlat(cTGAcc8Ch);
         SetLength(cFlat, Length(cTGAcc8Cl)*2);
         for i := 0 to High(cTGAcc8Cl) do
           begin cFlat[2*i] := cTGAcc8Cl[i, 0]; cFlat[2*i+1] := cTGAcc8Cl[i, 1]; end;
         fh := TGPoly3(dval, Length(cTGAcc8Ch), chFlat, Length(cTGAcc8Cl), cFlat, fl);
       end;
  end;

  // Recurrence multiplications
  wh := 1.0; wl := 0.0;
  if jm <> 0 then
  begin
    if jm > 0 then
    begin
      xph := x; xpl := 0.0;
      wh := xph;
      jSign := jm - 1;
      while jSign > 0 do
      begin
        if Abs(xph) > 1.0 then TGFastTwoSum(xph, lTmp, xph, 1.0)
        else                   TGFastTwoSum(xph, lTmp, 1.0, xph);
        xpl := xpl + lTmp;
        TGFastTwoSum(xph, xpl, xph, xpl);
        wh := TGMul3(xph, xpl, wh, wl, wl);
        if Abs(wh) > cTGScaleP518.f then
        begin
          wh := wh * cTGScaleM500.f;
          wl := wl * cTGScaleM500.f;
          eoff := eoff - 500;
        end;
        Dec(jSign);
      end;
    end
    else
    begin
      xph := x - 1.0; xpl := 0.0;
      wh := xph;
      jSign := -1 - jm;
      while jSign > 0 do
      begin
        TGFastTwoSum(xph, lTmp, xph, -1.0);
        xpl := xpl + lTmp;
        TGFastTwoSum(xph, xpl, xph, xpl);
        wh := TGMul3(xph, xpl, wh, wl, wl);
        Dec(jSign);
      end;
    end;
  end;

  if jm > 0 then
  begin
    rh := 1.0 / wh;
    rl := (pcr_fma(rh, -wh, 1.0) - wl * rh) * rh;
    fh := TGMul3(fh, fl, rh, rl, fl);
  end
  else if jm < 0 then
  begin
    fh := TGMul3(fh, fl, wh, wl, fl);
  end;

  // CRR adjustment
  if jm <= 0 then
  begin
    crr := ((cTGEps54.f + cTGEps107.f) - cTGEps54.f)
           + ((cTGEps53.f - cTGEps107.f) - cTGEps53.f);
    fl := fl + fh * (jm * crr);
  end
  else
  begin
    op := cTGEps53.f - cTGEps107.f;
    om := -cTGEps53.f + cTGEps107.f;
    crr := 0.0;
    if op = -om then crr := cTGEps53.f - op;
    fl := fl - fh * ((jm - 5) * crr * 1.04);
  end;

  eps := cTGEpsAcc.f * fh;
  ub := fh + (fl + eps); lb := fh + (fl - eps);
  res.f := fh + fl;
  re := Int64((res.u shr 52) and $7FF);
  if re + eoff <= 0 then  // subnormal case
  begin
    res.u := UInt64(Int64(res.u) - (Int64(eoff + re - 1) shl 52));
    res.u := res.u and (UInt64($FFF) shl 52);
    TGFastTwoSum(fh, lTmp, res.f, fh);
    fl := fl + lTmp;
    res.f := fh + fl;
    res.u := res.u and (not (UInt64($7FF) shl 52));
    TGRaiseUnderflow;
  end
  else
  begin
    res.u := UInt64(Int64(res.u) + (Int64(eoff) shl 52));
  end;
  if ub <> lb then
  begin
    Result := TGDatabase(x, res.f);
    Exit;
  end;
  Result := res.f;
end;

// ---------------------------------------------------------------------------
// pcr_tgamma — main entry
// ---------------------------------------------------------------------------
function pcr_tgamma_pas(x: Double): Double;
var
  t, th_u: Tb64u64;
  ax: UInt64;
  z, fx, fh, fl, ll, lh, eps, ub, lb: Double;
  k: Int64;
  ccFlat: TTGFlatArr;
  i, ip, e, j, jm: Int32;
  c0v, c4v, c8v, c12v, x2, x4, x8, ch, cl: Double;
  rh, rl, sh, sl, dx, rcp: Double;
  re: Int32;
  wh, wl, xph, xpl: Double;
  m, ipos, d, d2, d4: Double;
begin
  t.f := x;
  ax := t.u shl 1;
  if ax >= UInt64($FFE0000000000000) then
  begin
    if ax = UInt64($FFE0000000000000) then
    begin
      if (t.u shr 63) <> 0 then
      begin
        Result := x / x; Exit;
      end;
      Result := x; Exit;
    end;
    Result := x + x; Exit;
  end;

  z := x;
  if Abs(x) < 0.25 then
  begin
    if ax < cTGTinyAxThr then
    begin
      if x = cTGPow_m1024.f then
      begin
        Result := cTGSpecPow1024H.f + cTGSpecPow1024L.f; Exit;
      end;
      rh := 1.0 / x;
      if x = 0.0 then begin Result := rh; Exit; end;
      if pcr_fma(rh, x, -1.0) = 0.0 then rh := rh - 0.5;
      Result := rh; Exit;
    end;
    SetLength(ccFlat, 5*2);
    for i := 0 to 4 do
    begin
      ccFlat[2*i]   := cTGSmallCc[i, 0];
      ccFlat[2*i+1] := cTGSmallCc[i, 1];
    end;
    x2 := x * x; x4 := x2 * x2; x8 := x4 * x4;
    c0v := cTGSmallC[0].f + x*cTGSmallC[1].f + x2*(cTGSmallC[2].f + x*cTGSmallC[3].f);
    c4v := cTGSmallC[4].f + x*cTGSmallC[5].f + x2*(cTGSmallC[6].f + x*cTGSmallC[7].f);
    c8v := cTGSmallC[8].f + x*cTGSmallC[9].f + x2*(cTGSmallC[10].f + x*cTGSmallC[11].f);
    c12v:= cTGSmallC[12].f + x*cTGSmallC[13].f + x2*(cTGSmallC[14].f + x*cTGSmallC[15].f);
    c0v := c0v + x4*c4v;
    c8v := c8v + x4*c12v;
    cl := x * (c0v + x8 * c8v);
    ch := TGPolyDDD(x, 5, ccFlat, cl);
    fh := 1.0 / z;
    fl := pcr_fma(fh, -z, 1.0) * fh;
    TGFastSum(fh, fl, fh, fl, ch, cl);
    eps := fh * (3.5e-19 + (x2 * x4) * 4e-15);
    ub := fh + (fl + eps); lb := fh + (fl - eps);
    if ub <> lb then
    begin
      Result := TGAccurate(x); Exit;
    end;
    Result := ub;
    Exit;
  end;

  if x >= cTGOverThr.f then
  begin
    Result := cTGOvflPos.f + cTGOvflPos.f;
    Exit;
  end;

  fx := TGFloor(x);
  if fx = x then
  begin
    if x = 0.0 then begin Result := 1.0 / x; Exit; end;
    if x < 0.0 then begin Result := cNaNDouble; Exit; end;
    // x is positive integer ≤ 171 here (overflow already handled above)
    k := Trunc(fx);
    fh := 1.0; fl := 0.0; m := 1.0;
    i := 1;
    while i < k do
    begin
      fh := TGMulD(m, fh, fl, fl);
      m := m + 1.0;
      Inc(i);
    end;
    Result := fh + fl;
    Exit;
  end;

  if x <= -184.0 then
  begin
    // Non-integer x <= -184: |x| < 2^53 (else fx==x would have triggered above)
    k := Trunc(fx);
    if (k and 1) = 0 then Result := cTGSubMin.f * cTGSubMin.f
    else                  Result := cTGSubMin.f * cTGSubMinNeg.f;
    Exit;
  end;

  if x < -3.0 then
  begin
    TGFastTwoSum(lh, ll, -x, 1.0);
    lh := TGLgammaAsym(lh, ll);
    lh := TGExpd(lh, ll, e);
    fx := TGFloor(x); dx := x - fx; ip := Int32(Trunc(fx));
    sh := TGSinpid(dx, sl);
    lh := TGMul(sh, sl, lh, ll, ll);
    rcp := 1.0 / lh;
    rh := rcp * cTGPiH.f;
    rl := rcp * (cTGPiL.f - ll * rh - pcr_fma(rh, lh, -cTGPiH.f));
    if (ip and 1) <> 0 then
    begin
      rh := -rh; rl := -rl;
    end;
    eps := rh * (6.5e-21 - x * 1.46e-22);
    if ip >= -170 then
    begin
      ub := rh + (rl + eps); lb := rh + (rl - eps);
      if ub <> lb then begin Result := TGAccurate(x); Exit; end;
      th_u.f := ub;
      th_u.u := UInt64(Int64(th_u.u) - (Int64(e) shl 52));
      Result := th_u.f; Exit;
    end
    else
    begin
      th_u.f := rh;
      re := Int32((th_u.u shr 52) and $7FF);
      if (re - e) <= 0 then
      begin
        th_u.u := UInt64(Int64(th_u.u) + (Int64(e - re + 1) shl 52));
        th_u.u := th_u.u and (UInt64($FFF) shl 52);
        TGFastTwoSum(rh, fl, th_u.f, rh);
        rl := rl + fl;
        ub := rh + (rl + eps); lb := rh + (rl - eps);
        if ub <> lb then begin Result := TGAccurate(x); Exit; end;
        th_u.f := ub;
        th_u.u := th_u.u and (not (UInt64($7FF) shl 52));
        TGRaiseUnderflow;
        Result := th_u.f; Exit;
      end
      else
      begin
        ub := rh + (rl + eps); lb := rh + (rl - eps);
        if ub <> lb then begin Result := TGAccurate(x); Exit; end;
        th_u.f := ub;
        th_u.u := UInt64(Int64(th_u.u) - (Int64(e) shl 52));
        Result := th_u.f; Exit;
      end;
    end;
  end;

  if x > 4.0 then
  begin
    ll := 0.0;
    lh := TGLgammaAsym(x, ll);
    lh := TGExpd(lh, ll, e);
    eps := lh * (2e-21 + x * 1.5e-22);
    ub := lh + (ll + eps); lb := lh + (ll - eps);
    if ub <> lb then begin Result := TGAccurate(x); Exit; end;
    th_u.f := ub;
    th_u.u := UInt64(Int64(th_u.u) + (Int64(e) shl 52));
    Result := th_u.f; Exit;
  end;

  // 0.25 <= x <= 4 main path
  SetLength(ccFlat, 18*2);
  for i := 0 to 17 do
  begin
    ccFlat[2*i]   := cTGMainCc[i, 0];
    ccFlat[2*i+1] := cTGMainCc[i, 1];
  end;
  m := z - 3.5;
  ipos := pcr_roundeven(m);
  d := z - (ipos + 3.5);
  d2 := d*d; d4 := d2*d2;
  // FMA-contracted polynomial to match gcc -O2 -ffp-contract=fast output.
  fl := d * (pcr_fma(d, cTGMainC[11].f, cTGMainC[10].f)
            + d2*pcr_fma(d, cTGMainC[13].f, cTGMainC[12].f)
            + d4*(pcr_fma(d, cTGMainC[15].f, cTGMainC[14].f)
                  + d2*pcr_fma(d, cTGMainC[17].f, cTGMainC[16].f)));
  fh := TGPolyDDD(d, 10, ccFlat, fl);
  jm := Int32(Trunc(Abs(ipos)));
  wh := 1.0; wl := 0.0;
  xph := z; xpl := 0.0;
  if jm <> 0 then
  begin
    wh := xph;
    j := jm - 1;
    while j > 0 do
    begin
      if Abs(xph) > 1.0 then TGFastTwoSum(xph, fl, xph, 1.0)
      else                   TGFastTwoSum(xph, fl, 1.0, xph);
      xpl := xpl + fl;
      wh := TGMul(xph, xpl, wh, wl, wl);
      Dec(j);
    end;
  end;
  rh := 1.0 / wh;
  rl := (pcr_fma(rh, -wh, 1.0) - wl * rh) * rh;
  fh := TGMul(rh, rl, fh, fl, fl);
  eps := fh * 1e-21;
  ub := fh + (fl + eps); lb := fh + (fl - eps);
  if ub <> lb then begin Result := TGAccurate(x); Exit; end;
  Result := ub;
end;
