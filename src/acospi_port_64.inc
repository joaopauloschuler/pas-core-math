// ---------------------------------------------------------------------------
// pcr_acospi — correctly-rounded binary64 acos(x) / pi.
// Ported from core-math/src/binary64/acospi/acospi.c
//   (Paul Zimmermann, Tom Hubrecht; algorithm derived from acos.c).
// Tables auto-generated by tools/acospi_gen.py (see acospi_const.inc).
// ---------------------------------------------------------------------------

const
  cAcospiOnePiH:  Tb64u64 = (u:$3FD45F306DC9C883);  //  0x1.45f306dc9c883p-2
  cAcospiOnePiL:  Tb64u64 = (u:QWord($BC76B01EC5417056));  // -0x1.6b01ec5417056p-56
  cAcospiPiHi:    Tb64u64 = (u:$400921FB54442D18);  //  0x1.921fb54442d18p+1
  cAcospiPiLo:    Tb64u64 = (u:$3CA1A62633145C07);  //  0x1.1a62633145c07p-53
  cAcospiPiHalfH: Tb64u64 = (u:$3FF921FB54442D18);  //  pi/2 hi
  cAcospiPiHalfL: Tb64u64 = (u:$3C91A62633145C07);  //  pi/2 lo
  cAcospiI0Bias:  Tb64u64 = (u:$3C91A62792C17E8C);  //  0x4.6989e4b05fa3p-56 (i=0 only)
  cAcospiSmallX:  Tb64u64 = (u:$3C9921FB54442D18);  //  0x1.921fb54442d18p-54
  cAcospiOneNeg55:Tb64u64 = (u:$3C80000000000000);  //  0x1p-55
  cAcospiOneNeg54:Tb64u64 = (u:$3C90000000000000);  //  0x1p-54
  // Two hard-coded acospi exceptions for 0.5 <= x < 1
  cAcospiEx1In:   Tb64u64 = (u:$3FEB32B7AC93DDEF);  //  0x1.b32b7ac93ddefp-1
  cAcospiEx1Hi:   Tb64u64 = (u:$3FC69C0E1DFBF177);  //  0x1.69c0e1dfbf177p-3
  cAcospiEx1Lo:   Tb64u64 = (u:$39316BEADD718BAF);  //  0x1.16beadd718bafp-108 (sign applied at use)
  cAcospiEx2In:   Tb64u64 = (u:$3FEE55A7FA9A24C4);  //  0x1.e55a7fa9a24c4p-1
  cAcospiEx2Hi:   Tb64u64 = (u:$3FBA67C4D04A9236);  //  0x1.a67c4d04a9236p-4
  cAcospiEx2Lo:   Tb64u64 = (u:$391EDC5FCB35E5E3);  //  0x1.edc5fcb35e5e3p-110 (sign applied at use)

  // Constant DEGREE+LARGE+1 = 19 → index of polynomial leading "h" in T2 row.
  // Constant DEGREE+LARGE+2 = 20 → index of evaluation point xmid in T2 row.

{$I acospi_const_64.inc}

// Local d_mul matching acospi.c grouping exactly (order ah*bl first, then al*bh).
// pcr_d_mul does al*bh first then ah*bl — a different FMA chain that drifts 1 ULP.
procedure AcospiDMul(var hi, lo: Double; ah, al, bh, bl: Double); inline;
var ah_save, t: Double;
begin
  ah_save := ah;
  pcr_a_mul(hi, t, ah_save, bh);
  t  := pcr_fma(ah, bl, t);
  lo := pcr_fma(al, bh, t);
end;

// AcospiSqrtDD — sqrt of 0 <= x <= 0.25, returns h, *l = lo such that h+l ~ sqrt(x)
function AcospiSqrtDD(x: Double; out l: Double): Double; inline;
var h, e: Double;
begin
  h := Sqrt(x);
  e := -pcr_fma(h, h, -x);
  l := e / (h + h);
  Result := h;
end;

function AcospiAccurate(x: Double): Double;
const
  ACOSPI_DEGREE = 11;
  ACOSPI_LARGE  = 8;
  // index "DEGREE+LARGE" = 19 holds polynomial leading h; "DEGREE+LARGE+1" = 20 holds xmid.
var
  ix: Tb64u64;
  absx, y, h, l, u, v, h1, l1, ax_p1: Double;
  i, a, b, c, j: Int32;
  hi: Double;
  del: Int32;
  uHi, uLo, p2j, p2j1: Double;
begin
  ix.f := x;
  ix.u := ix.u and UInt64($7FFFFFFFFFFFFFFF);
  absx := ix.f;
  ax_p1 := Double(1.0) + absx;            // 1 <= ax_p1 <= 2
  ix.f  := ax_p1;
  if ix.f = Double(2.0) then i := 127
  else i := Int32((ix.u shr 45) and UInt64($7F));

  if i < 64 then  // |x| < 0.5
  begin
    // Binary-search exception table (114 entries). Pre-condition: a+1<>b.
    a := 0; b := 114;
    while a + 1 <> b do
    begin
      c := (a + b) shr 1;
      if cAcospiEx[c, 0].f <= x then a := c else b := c;
    end;
    if x = cAcospiEx[a, 0].f then
    begin
      hi := cAcospiEx[a, 1].f;
      if hi > Double(0.0) then del := cAcospiExRnd[a]
      else del := -cAcospiExRnd[a];
      Result := hi + hi * cAcospiOneNeg54.f * Double(del);
      Exit;
    end;
    // |x| <= pi/2 * 2^-54  ⇒ acospi(x) rounds to 0.5
    if absx <= cAcospiSmallX.f then
    begin
      Result := pcr_fma(x, -Double(0.125), Double(0.5));
      Exit;
    end;

    // p = T2[i]; y = absx - xmid; h = leading; l = 0
    y := absx - cAcospiT2[i, 20].f;
    h := cAcospiT2[i, 19].f;
    l := Double(0.0);
    for j := ACOSPI_DEGREE - 1 downto 0 do
    begin
      if j >= ACOSPI_LARGE then
      begin
        h := cAcospiT2[i, ACOSPI_LARGE + j].f + h * y;
        l := Double(0.0);
      end
      else
      begin
        // mul2_1: a_mul(uHi, uLo, h, y); uLo += l*y
        pcr_a_mul(uHi, uLo, h, y);
        uLo := uLo + l * y;
        p2j  := cAcospiT2[i, 2*j].f;
        p2j1 := cAcospiT2[i, 2*j + 1].f;
        if Abs(p2j) >= Abs(uHi) then
          pcr_fasttwosum(h, l, p2j, uHi)
        else
          pcr_fasttwosum(h, l, uHi, p2j);
        l := l + p2j1 + uLo;
      end;
    end;
    if x < Double(0.0) then begin h := -h; l := -l; end;
    pcr_fasttwosum(u, v, cAcospiPiHalfH.f, h);
    v := v + cAcospiPiHalfL.f + l;
    // multiply by 1/pi
    AcospiDMul(u, v, u, v, cAcospiOnePiH.f, cAcospiOnePiL.f);
    Result := u + v;
  end
  else  // 0.5 <= |x| < 1
  begin
    // Hard-coded acospi exceptions in this range
    if x = cAcospiEx1In.f then
    begin
      Result := cAcospiEx1Hi.f - cAcospiEx1Lo.f;
      Exit;
    end;
    if x = cAcospiEx2In.f then
    begin
      Result := cAcospiEx2Hi.f - cAcospiEx2Lo.f;
      Exit;
    end;

    // h1 + l1 ~ sqrt(1 - |x|)
    h1 := AcospiSqrtDD(Double(1.0) - absx, l1);
    y := absx - cAcospiT2[i, 20].f;
    h := cAcospiT2[i, 19].f;
    l := Double(0.0);
    for j := ACOSPI_DEGREE - 1 downto 0 do
    begin
      if j >= ACOSPI_LARGE then
      begin
        h := cAcospiT2[i, ACOSPI_LARGE + j].f + h * y;
        l := Double(0.0);
      end
      else
      begin
        pcr_a_mul(uHi, uLo, h, y);
        uLo := uLo + l * y;
        p2j  := cAcospiT2[i, 2*j].f;
        p2j1 := cAcospiT2[i, 2*j + 1].f;
        // Note: this branch always uses fast_two_sum(h,l,p2j,u) (no abs check).
        pcr_fasttwosum(h, l, p2j, uHi);
        l := l + p2j1 + uLo;
      end;
    end;
    // (h + l) * (h1 + l1)
    pcr_a_mul(u, v, h1, h);
    v := v + l1 * h + h1 * l;
    if x < Double(0.0) then
    begin
      pcr_fasttwosum(u, l, cAcospiPiHi.f, -u);
      v := l + cAcospiPiLo.f - v;
    end;
    AcospiDMul(u, v, u, v, cAcospiOnePiH.f, cAcospiOnePiL.f);
    Result := u + v;
  end;
end;

function pcr_acospi(x: Double): Double;
var
  ix, vx: Tb64u64;
  absx, y, yy, p56, p34, p23, p45, zh, zl, du, dv, h1, l1, l1zh, h1zl: Double;
  err, lhs, rhs: Double;
  k_hi: UInt32;
  i: Int32;
begin
  ix.f := x;
  // sign-clear high word
  ix.u := ix.u and UInt64($7FFFFFFFFFFFFFFF);
  absx := ix.f;
  k_hi := UInt32(ix.u shr 32);

  if k_hi < UInt32($3FE80000) then  // |x| < 0.75
  begin
    if k_hi < UInt32($3C9921FB) then  // |x| < pi/2 * 2^-54 boundary
    begin
      // acospi(x) ~ 1/2 - x/pi, fast path
      Result := pcr_fma(-cAcospiOneNeg55.f, x, Double(0.5));
      Exit;
    end;
    vx.f := Double(1.0) + absx;
    i := Int32((vx.u shr 44) and UInt64($FF));
    if i = 192 then i := 191;
    // T[i][7] = xmid
    y := absx - cAcospiT[i, 7].f;
    yy := y * y;
    p56 := pcr_fma(cAcospiT[i, 6].f, y, cAcospiT[i, 5].f);
    p34 := pcr_fma(cAcospiT[i, 4].f, y, cAcospiT[i, 3].f);
    zh  := pcr_fma(p56, yy, p34);
    zh  := pcr_fma(zh, y, cAcospiT[i, 2].f);
    pcr_fasttwosum(zh, zl, cAcospiT[i, 1].f, y * zh);
    pcr_fasttwosum(du, dv, cAcospiT[i, 0].f, zh * y);
    dv  := pcr_fma(zl, y, dv);
    if i = 0 then
      dv := dv + cAcospiI0Bias.f;
    if x < Double(0.0) then
    begin
      pcr_fasttwosum(du, zl, cAcospiPiHi.f, -du);
      dv := cAcospiPiLo.f + zl - dv;
    end;
    AcospiDMul(du, dv, du, dv, cAcospiOnePiH.f, cAcospiOnePiL.f);
    err := cAcospiErr[i].f;
    lhs := du + (dv - err);
    rhs := du + (dv + err);
    if lhs <> rhs then
      Result := AcospiAccurate(x)
    else
      Result := lhs;
  end
  else if k_hi < UInt32($3FF00000) then  // 0.75 <= |x| < 1
  begin
    vx.f := Double(1.0) + absx;
    if vx.f = Double(2.0) then
      i := 255
    else
      i := Int32((vx.u shr 44) and UInt64($FF));
    // T[i][6] = xmid for this branch
    y := absx - cAcospiT[i, 6].f;
    h1 := AcospiSqrtDD(Double(1.0) - absx, l1);
    yy := y * y;
    p45 := pcr_fma(cAcospiT[i, 5].f, y, cAcospiT[i, 4].f);
    p23 := pcr_fma(cAcospiT[i, 3].f, y, cAcospiT[i, 2].f);
    zh  := pcr_fma(p45, yy, p23);
    zh  := pcr_fma(zh, y, cAcospiT[i, 1].f);
    pcr_fasttwosum(zh, zl, cAcospiT[i, 0].f, zh * y);
    l1zh := l1 * zh;
    h1zl := h1 * zl;
    pcr_a_mul(du, dv, h1, zh);
    dv := dv + l1zh + h1zl;
    if x < Double(0.0) then
    begin
      pcr_fasttwosum(du, zl, cAcospiPiHi.f, -du);
      dv := zl + cAcospiPiLo.f - dv;
    end;
    AcospiDMul(du, dv, du, dv, cAcospiOnePiH.f, cAcospiOnePiL.f);
    err := cAcospiErr[i].f;
    lhs := du + (dv - err);
    rhs := du + (dv + err);
    if lhs <> rhs then
      Result := AcospiAccurate(x)
    else
      Result := lhs;
  end
  else  // |x| >= 1
  begin
    if (k_hi = UInt32($3FF00000)) and ((ix.u and UInt64($FFFFFFFF)) = 0) then
    begin
      // |x| = 1 exactly: acospi(1)=0, acospi(-1)=1
      if x > Double(0.0) then Result := Double(0.0) else Result := Double(1.0);
      Exit;
    end;
    if (k_hi > UInt32($7FF00000)) or
       ((k_hi = UInt32($7FF00000)) and ((ix.u and UInt64($FFFFFFFF)) <> 0)) then
    begin
      Result := x + x;  // NaN
      Exit;
    end;
    // |x| > 1 (finite) or |x| = +/-Inf: return Inf - Inf = NaN
    Result := (Double(1.0) / Double(0.0)) - (Double(1.0) / Double(0.0));
  end;
end;
