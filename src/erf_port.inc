// ===========================================================================
// pcr_erf — correctly-rounded binary64 erf(x).
// Ported from core-math/src/binary64/erf/erf.c by Paul Zimmermann.
// Tables (cErfC, cErfC2, cErfP, cErfC0, cErfExTiny, cErfExAcc) are
// auto-generated by tmp/erf_gen.py into erf_const.inc.
// ===========================================================================

const
{$I erf_const.inc}
  cErfCH:    Tb64u64 = (u:$3FF20DD750429B6D); // 2/sqrt(pi) hi
  cErfCL:    Tb64u64 = (u:$3C71AE3A914FED80); // 2/sqrt(pi) lo
  cErfFastErr0: Tb64u64 = (u:$3BA7800000000000); // 0x1.78p-69
  cErfFastErr1: Tb64u64 = (u:$3BA1100000000000); // 0x1.11p-69
  cErfP106:  Tb64u64 = (u:$4690000000000000); // 0x1p+106
  cErfPm106: Tb64u64 = (u:$3950000000000000); // 0x1p-106

// ----------------------------------------------------------------------------
// Local helpers
function ErfATwoSum(a, b: Double; out lo: Double): Double; inline;
var hi, aa, bb, da, db: Double;
begin
  hi := a + b;
  aa := hi - b;
  bb := hi - aa;
  da := a - aa;
  db := b - bb;
  lo := da + db;
  Result := hi;
end;

// ----------------------------------------------------------------------------
// Fast path: 0 <= z, z >= 2^-61, z <= 0x1.7afb48dc96626p+2.
// Returns the relative error bound (0x1.78p-69 for z<1/16; 0x1.11p-69 otherwise).
function ErfFast(out h, l: Double; z: Double): Double;
var
  z2h, z2l, z4, z2: Double;
  c9, c7, c5, c3h, c3l, c2h, c2l, th, tl: Double;
  hcopy: Double;
  iv: Int32;
  v: Double;
begin
  if z < Double(0.0625) then
  begin
    z2h := z * z;
    z2l := pcr_fma(z, z, -z2h);
    z4  := z2h * z2h;
    c9  := pcr_fma(cErfC0[7].f, z2h, cErfC0[6].f);
    c5  := pcr_fma(cErfC0[5].f, z2h, cErfC0[4].f);
    c5  := pcr_fma(c9, z4, c5);
    th  := z2h * c5;
    tl  := pcr_fma(z2h, c5, -th);
    pcr_fasttwosum(h, l, cErfC0[2].f, th);
    l := l + (tl + cErfC0[3].f);
    hcopy := h;
    th := z2h * h;
    tl := pcr_fma(z2h, h, -th);
    tl := tl + pcr_fma(z2h, l, cErfC0[1].f);
    pcr_fasttwosum(h, l, cErfC0[0].f, th);
    l := l + pcr_fma(z2l, hcopy, tl);
    th := h * z;
    tl := pcr_fma(h, z, -th);
    h := th;
    l := pcr_fma(l, z, tl);
    Result := cErfFastErr0.f;
    Exit;
  end;

  v   := Double(16.0) * z;
  iv  := Trunc(v);                  // floor for positive
  z := (z - Double(0.03125)) - Double(0.0625) * Double(iv);
  // |z| <= 1/32; 1 <= iv <= 94; row index iv-1.
  z2 := z * z;
  z4 := z2 * z2;

  c9  := pcr_fma(cErfC[iv-1, 12].f, z, cErfC[iv-1, 11].f);
  c7  := pcr_fma(cErfC[iv-1, 10].f, z, cErfC[iv-1,  9].f);
  c5  := pcr_fma(cErfC[iv-1,  8].f, z, cErfC[iv-1,  7].f);
  pcr_fasttwosum(c3h, c3l, cErfC[iv-1, 5].f, z * cErfC[iv-1, 6].f);
  c7 := pcr_fma(c9, z2, c7);
  pcr_fasttwosum(c3h, tl, c3h, c5 * z2);
  c3l := c3l + tl;
  pcr_fasttwosum(c3h, tl, c3h, c7 * z4);
  c3l := c3l + tl;

  th := z * c3h;
  tl := pcr_fma(z, c3h, -th);
  pcr_fasttwosum(c2h, c2l, cErfC[iv-1, 4].f, th);
  c2l := c2l + pcr_fma(z, c3l, tl);

  th := z * c2h;
  tl := pcr_fma(z, c2h, -th);
  pcr_fasttwosum(h, l, cErfC[iv-1, 2].f, th);
  l := l + (tl + pcr_fma(z, c2l, cErfC[iv-1, 3].f));

  th := z * h;
  tl := pcr_fma(z, h, -th);
  tl := pcr_fma(z, l, tl);
  pcr_fasttwosum(h, l, cErfC[iv-1, 0].f, th);
  l := l + (tl + cErfC[iv-1, 1].f);
  Result := cErfFastErr1.f;
end;

// ----------------------------------------------------------------------------
// Accurate-tiny path: 0 <= z < 1/8, z >= 2^-61. Uses 171-entry exception table
// (binary search) and degree-21 polynomial p[].
procedure ErfAccurateTiny(out h, l: Double; z: Double);
var
  i, j, k: Int32;
  p: array[0..14] of Double;
  z2, th, tl: Double;
  a: Int32;
begin
  i := 0;
  j := 171;
  while (i + 1) < j do
  begin
    k := (i + j) shr 1;
    if cErfExTiny[k, 0].f <= z then i := k else j := k;
  end;
  if z = cErfExTiny[i, 0].f then
  begin
    h := cErfExTiny[i, 1].f;
    l := cErfExTiny[i, 2].f;
    Exit;
  end;

  for a := 0 to 14 do p[a] := cErfP[a].f;
  z2 := z * z;
  h  := p[14]; // degree 21
  // for a = 19 down to 13 step -2 -> indices 13,12,11,10
  h := pcr_fma(h, z2, p[13]);
  h := pcr_fma(h, z2, p[12]);
  h := pcr_fma(h, z2, p[11]);
  h := pcr_fma(h, z2, p[10]);
  l := Double(0.0);
  // Loop a = 11 step -2 down to 9 (single-double coefficients d11, d9).
  for a := 11 downto 9 do
  begin
    if (a and 1) = 0 then continue;
    // multiply (h, l) by z^2: a_mul(th,tl,h,z); tl=fma(l,z,tl); a_mul(h,l,th,z); l=fma(tl,z,l)
    th := h * z;  tl := pcr_fma(h, z, -th);
    tl := pcr_fma(l, z, tl);
    h  := th * z; l  := pcr_fma(th, z, -h);
    l  := pcr_fma(tl, z, l);
    pcr_fasttwosum(h, tl, p[(a div 2) + 4], h);
    l := l + tl;
  end;
  // Loop a = 7 step -2 down to 1 (dd coefficients): pairs (p[a-1], p[a]).
  for a := 7 downto 1 do
  begin
    if (a and 1) = 0 then continue;
    th := h * z;  tl := pcr_fma(h, z, -th);
    tl := pcr_fma(l, z, tl);
    h  := th * z; l  := pcr_fma(th, z, -h);
    l  := pcr_fma(tl, z, l);
    pcr_fasttwosum(h, tl, p[a-1], h);
    l := l + (p[a] + tl);
  end;
  // Multiply by z.
  th := h * z; tl := pcr_fma(h, z, -th);
  h := th;
  l := pcr_fma(l, z, tl);
end;

// ----------------------------------------------------------------------------
// Accurate path: 0 <= z, z >= 2^-61, z <= 0x1.7afb48dc96626p+2.
procedure ErfAccurate(out h, l: Double; z: Double);
var
  i: Int32;
  iv: Int32;
  zr: Double;
  th, tl: Double;
  j: Int32;
  v: Double;
begin
  for i := 0 to 4 do
    if z = cErfExAcc[i, 0].f then
    begin
      h := cErfExAcc[i, 1].f;
      l := cErfExAcc[i, 2].f;
      Exit;
    end;

  if z < Double(0.125) then
  begin
    ErfAccurateTiny(h, l, z);
    Exit;
  end;

  v  := Double(8.0) * z;
  iv := Trunc(v);                 // floor for positive
  zr := (z - Double(0.0625)) - Double(0.125) * Double(iv);
  // row index iv-1 in C2; 1 <= iv <= 47.
  h := cErfC2[iv-1, 26].f;        // degree 18
  for j := 17 downto 11 do
    h := pcr_fma(h, zr, cErfC2[iv-1, 8 + j].f);
  l := Double(0.0);
  for j := 10 downto 8 do
  begin
    th := h * zr; tl := pcr_fma(h, zr, -th);
    tl := pcr_fma(l, zr, tl);
    h  := ErfATwoSum(cErfC2[iv-1, 8 + j].f, th, l);
    l := l + tl;
  end;
  for j := 7 downto 0 do
  begin
    th := h * zr; tl := pcr_fma(h, zr, -th);
    tl := pcr_fma(l, zr, tl);
    h  := ErfATwoSum(cErfC2[iv-1, 2*j].f, th, l);
    l := l + (cErfC2[iv-1, 2*j + 1].f + tl);
  end;
end;

// ----------------------------------------------------------------------------
function pcr_erf(x: Double): Double;
var
  ix, t, u, v: Tb64u64;
  z, h, l, err, sx, y, yscaled, res, left, right, os: Double;
begin
  z := pcr_fabs(x);
  ix.f := z;
  // |x| > 0x1.7afb48dc96626p+2 → saturate
  if ix.u > UInt64($4017AFB48DC96626) then
  begin
    os := pcr_copysign(Double(1.0), x);
    if ix.u > UInt64($7FF0000000000000) then begin Result := x + x; Exit; end; // NaN
    if ix.u = UInt64($7FF0000000000000) then begin Result := os; Exit; end;    // +/-Inf
    Result := os - Double(5.5511151231257827e-17) * os; // os - 0x1p-54 * os
    Exit;
  end;

  // Tiny: |x| < 2^-61
  if ix.u < UInt64($3C20000000000000) then
  begin
    if x = Double(0.0) then begin Result := x; Exit; end;
    y       := cErfCH.f * x;
    sx      := x * cErfP106.f;       // x * 2^106
    h       := cErfCH.f * sx;
    l       := pcr_fma(cErfCH.f, sx, -h);
    l       := pcr_fma(cErfCL.f, sx, l);
    yscaled := y * cErfP106.f;       // y * 2^106 (exact: same magnitude as h)
    l       := l + (h - yscaled);
    res     := pcr_fma(l, cErfPm106.f, y);
    Result  := res;
    Exit;
  end;

  err := ErfFast(h, l, z);
  // Ziv test: apply sign of x to h and l, then check if [left, right] collapses.
  u.f := h; v.f := l;
  t.f := x;
  u.u := u.u xor (t.u and UInt64($8000000000000000));
  v.u := v.u xor (t.u and UInt64($8000000000000000));
  left  := u.f + pcr_fma(err, -u.f, v.f);
  right := u.f + pcr_fma(err,  u.f, v.f);
  if left = right then begin Result := left; Exit; end;

  ErfAccurate(h, l, z);
  if x >= Double(0.0) then
    Result := h + l
  else
    Result := (-h) + (-l);
end;
