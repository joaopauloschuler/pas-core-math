// ---------------------------------------------------------------------------
// Local primitives matching lgamma.c grouping (no renormalization).
// ---------------------------------------------------------------------------

procedure LgFastTwoSum(out s, e: Double; x, y: Double); inline;
var ss: Double;
begin
  ss := x + y;
  e  := y - (ss - x);
  s  := ss;
end;

procedure LgTwoSum(out h, e: Double; x, y: Double); inline;
begin
  if Abs(x) > Abs(y) then LgFastTwoSum(h, e, x, y)
  else                    LgFastTwoSum(h, e, y, x);
end;

procedure LgFastSum(out h, l: Double; xh, xl, yh, yl: Double); inline;
var sl: Double;
begin
  LgFastTwoSum(h, sl, xh, yh);
  l := (xl + yl) + sl;
end;

procedure LgSumDD(out h, l: Double; xh, xl, yh, yl: Double); inline;
var sl: Double;
begin
  if Abs(xh) > Abs(yh) then LgFastTwoSum(h, sl, xh, yh)
  else                       LgFastTwoSum(h, sl, yh, xh);
  l := (xl + yl) + sl;
end;

function LgMul(xh, xl, ch, cl: Double; out l: Double): Double; inline;
var ahhh: Double;
begin
  ahhh := ch * xh;
  l    := (ch * xl + cl * xh) + pcr_fma(ch, xh, -ahhh);
  Result := ahhh;
end;

function LgMulD(x, ch, cl: Double; out l: Double): Double; inline;
var ahhh: Double;
begin
  ahhh := ch * x;
  l    := cl * x + pcr_fma(ch, x, -ahhh);
  Result := ahhh;
end;

function LgPolyDFlat(x: Double; n: Int32; const c: array of Double): Double;
var i: Int32; chv: Double;
begin
  i := n - 1;
  chv := c[i];
  Dec(i);
  while i >= 0 do
  begin
    chv := c[i] + x * chv;
    Dec(i);
  end;
  Result := chv;
end;

function LgPolyDD(xh, xl: Double; n: Int32;
                  const c: array of Tb64u64; var l: Double): Double;
var i: Int32; chv, cl: Double;
begin
  i := n - 1;
  LgFastTwoSum(chv, cl, c[2*i].f, l);
  cl := cl + c[2*i + 1].f;
  Dec(i);
  while i >= 0 do
  begin
    chv := LgMul(xh, xl, chv, cl, cl);
    LgFastSum(chv, cl, c[2*i].f, c[2*i + 1].f, chv, cl);
    Dec(i);
  end;
  l := cl;
  Result := chv;
end;

function LgPolyDDD(x: Double; n: Int32;
                   const c: array of Tb64u64; var l: Double): Double;
var i: Int32; chv, cl: Double;
begin
  i := n - 1;
  LgFastTwoSum(chv, cl, c[2*i].f, l);
  cl := cl + c[2*i + 1].f;
  Dec(i);
  while i >= 0 do
  begin
    chv := LgMulD(x, chv, cl, cl);
    LgFastSum(chv, cl, c[2*i].f, c[2*i + 1].f, chv, cl);
    Dec(i);
  end;
  l := cl;
  Result := chv;
end;

function LgFloor(x: Double): Double; inline;
var ix: Double;
begin
  ix := System.Int(x);
  if (x < 0.0) and (ix <> x) then ix := ix - 1.0;
  Result := ix;
end;

function LgCopySignSign(x: Double): Double; inline;
// Returns +1 if sign-bit clear (incl +0), -1 if sign-bit set (incl -0).
var t: Tb64u64;
begin
  t.f := x;
  if (t.u shr 63) <> 0 then Result := -1.0 else Result := 1.0;
end;

type TLgFlatArr = array of Tb64u64;

function LgFlat2(const t: array of Tb64u64): TLgFlatArr;
var i: Int32;
begin
  Result := nil;
  SetLength(Result, Length(t));
  for i := 0 to High(t) do Result[i] := t[i];
end;

// Flatten a 2D [N][2] constant table by raw memory copy.
function LgPairsFlat(const src; nPairs: Int32): TLgFlatArr;
begin
  Result := nil;
  SetLength(Result, 2 * nPairs);
  Move(src, Result[0], 2 * nPairs * SizeOf(Tb64u64));
end;

// ---------------------------------------------------------------------------
// as_logd
// ---------------------------------------------------------------------------
function LgLogd(x: Double; out l: Double): Double;
var
  t: Tb64u64;
  ex, ee, i1, i2, kk: Int32;
  ed, r, o, dxl, dxh, dx, dx2, f, lt, lh, ll: Double;
  iIdx: UInt64;
  dRaw, j: Int64;
begin
  t.f := x;
  ex := Int32(t.u shr 52);
  if ex = 0 then
  begin
    kk := pcr_clzll(t.u);
    t.u := t.u shl (kk - 11);
    ex := -(kk - 12);
  end;
  ee := ex - $3FF;
  t.u := t.u and (UInt64($FFFFFFFFFFFFFFFF) shr 12);
  ed := ee;
  iIdx := t.u shr (52 - 5);
  dRaw := Int64(t.u and (UInt64($FFFFFFFFFFFFFFFF) shr 17));
  j := SarInt64(
        Int64(t.u + (UInt64(cLgammaLogB[iIdx].c0) shl 33))
          + Int64(cLgammaLogB[iIdx].c1) * SarInt64(dRaw, 16),
        52 - 10);
  t.u := t.u or (UInt64($3FF) shl 52);
  i1 := Int32(j shr 5);
  i2 := Int32(j and $1F);
  r  := cLgammaLogR1[i1].f * cLgammaLogR2[i2].f;
  o  := r * t.f;
  dxl := pcr_fma(r, t.f, -o);
  dxh := o - 1.0;
  dx  := pcr_fma(r, t.f, -1.0);
  dx2 := dx * dx;
  f := dx2 * ((cLgammaLogC[0].f + dx*cLgammaLogC[1].f)
              + dx2*(cLgammaLogC[2].f + dx*cLgammaLogC[3].f));
  lt := (cLgammaLogL1[i1, 1].f + cLgammaLogL2[i2, 1].f) + ed * cLgammaLn2Hi.f;
  lh := lt + dxh;
  ll := (lt - lh) + dxh;
  ll := ll + ((cLgammaLogL1[i1, 0].f + cLgammaLogL2[i2, 0].f) + cLgammaLn2Lo.f * ed) + dxl;
  ll := ll + f;
  l  := ll;
  Result := lh;
end;

// ---------------------------------------------------------------------------
// as_logd_accurate
// ---------------------------------------------------------------------------
function LgLogdAcc(x: Double; out l, l_: Double): Double;
var
  t: Tb64u64;
  ex, ee, i1, i2, kk: Int32;
  ed, r, o, dxl, dxh, fl, fh, s0, s1, s2, L0, L1, L2: Double;
  iIdx: UInt64;
  dRaw, j: Int64;
  cArr: TLgFlatArr;
begin
  t.f := x;
  ex := Int32(t.u shr 52);
  if ex = 0 then
  begin
    kk := pcr_clzll(t.u);
    t.u := t.u shl (kk - 11);
    ex := -(kk - 12);
  end;
  ee := ex - $3FF;
  t.u := t.u and (UInt64($FFFFFFFFFFFFFFFF) shr 12);
  ed := ee;
  iIdx := t.u shr (52 - 5);
  dRaw := Int64(t.u and (UInt64($FFFFFFFFFFFFFFFF) shr 17));
  j := SarInt64(
        Int64(t.u + (UInt64(cLgammaLogB[iIdx].c0) shl 33))
          + Int64(cLgammaLogB[iIdx].c1) * SarInt64(dRaw, 16),
        52 - 10);
  t.u := t.u or (UInt64($3FF) shl 52);
  i1 := Int32(j shr 5);
  i2 := Int32(j and $1F);
  r  := cLgammaLogR1[i1].f * cLgammaLogR2[i2].f;
  o  := r * t.f;
  dxl := pcr_fma(r, t.f, -o);
  dxh := o - 1.0;

  LgFastTwoSum(dxh, dxl, dxh, dxl);
  fl := dxh * (cLgammaLogAC[6, 0].f
        + dxh * (cLgammaLogAC[7, 0].f + dxh * cLgammaLogAC[8, 0].f));
  cArr := LgPairsFlat(cLgammaLogAC, 9);
  fh := LgPolyDD(dxh, dxl, 6, cArr, fl);
  fh := LgMul(dxh, dxl, fh, fl, fl);

  s2 := cLgammaLogH1[i1, 2].f + cLgammaLogH2[i2, 2].f;
  s1 := cLgammaLogH1[i1, 1].f + cLgammaLogH2[i2, 1].f;
  s0 := cLgammaLogH1[i1, 0].f + cLgammaLogH2[i2, 0].f;
  L0 := cLgammaLn2H3.f * ed;
  L1 := cLgammaLn2M3.f * ed;
  L2 := cLgammaLn2L3.f * ed;
  L0 := L0 + s2;
  LgSumDD(L1, L2, L1, L2, s1, s0);
  LgSumDD(L1, L2, L1, L2, fh, fl);
  LgFastTwoSum(L0, L1, L0, L1);
  LgFastTwoSum(L1, L2, L1, L2);
  l := L1;
  l_ := L2;
  Result := L0;
end;

// ---------------------------------------------------------------------------
// as_sinpipid
// ---------------------------------------------------------------------------
function LgSinpipid(x: Double; out l: Double): Double;
var
  ax, sx, ix, d, d2, P, Q, z, z2, z2l, fl, fh, e: Double;
  ky, kx: Int32;
  shv, slv, chv, cl, qh, ql, th, tl, ph, pl, fll: Double;
begin
  x := x - 0.5;
  ax := Abs(x);
  sx := ax * 128.0;
  ix := pcr_roundeven(sx);
  ky := Int32(Trunc(ix));
  kx := 64 - ky;
  if kx < 2 then
  begin
    z  := 0.5 - ax;
    z2 := z * z;
    z2l := pcr_fma(z, z, -z2);
    fl := z2 * (cLgammaSinKx2Cl[0].f
                + z2 * (cLgammaSinKx2Cl[1].f + z2 * cLgammaSinKx2Cl[2].f));
    LgFastTwoSum(fh, fl, cLgammaSinKx2C[0].f, fl);
    fl := fl + cLgammaSinKx2C[1].f;
    fh := LgMul(z2, z2l, fh, fl, fl);
    fh := LgMulD(z, fh, fl, fl);
    LgFastTwoSum(fh, e, z, fh);
    fl := fl + e;
    l := fl;
    Result := fh;
    Exit;
  end;
  d := ix - sx;
  d2 := d * d;
  shv := cLgammaStpi[kx, 1].f; slv := cLgammaStpi[kx, 0].f;
  chv := cLgammaStpi[ky, 1].f; cl  := cLgammaStpi[ky, 0].f;

  P := d2 * (cLgammaSinC[1].f + d2 * (cLgammaSinC[2].f + d2 * cLgammaSinC[3].f));
  Q := d2 * (cLgammaSinS[1].f + d2 * (cLgammaSinS[2].f + d2 * cLgammaSinS[3].f));

  LgFastTwoSum(qh, ql, cLgammaSinS[0].f, Q);
  ql := ql + cLgammaSinS0[0].f;
  chv := LgMul(qh, ql, chv, cl, cl);

  LgFastTwoSum(th, tl, cLgammaSinC[0].f, P);
  tl := tl + cLgammaSinC0[0].f;
  th := LgMulD(d, th, tl, tl);

  ph := LgMul(th, tl, shv, slv, pl);
  LgFastSum(chv, cl, chv, cl, ph, pl);
  chv := LgMulD(d, chv, cl, cl);
  LgFastSum(shv, fll, shv, slv, chv, cl);
  l := fll;
  Result := shv;
end;

// ---------------------------------------------------------------------------
// as_sinpipid_accurate
// ---------------------------------------------------------------------------
function LgSinpipidAcc(x: Double; out l: Double): Double;
var
  ix, d, d2h, d2l: Double;
  ky, kx: Int32;
  shv, slv, chv, cl, Pl, Ph, Ql, Qh, outl: Double;
  cArr, sArr: TLgFlatArr;
begin
  x := x - 0.5;
  x := Abs(x);
  x := x * 128.0;
  ix := pcr_roundeven(x);
  d := ix - x;
  ky := Int32(Trunc(ix));
  kx := 64 - ky;
  shv := cLgammaStpi[kx, 1].f; slv := cLgammaStpi[kx, 0].f;
  chv := cLgammaStpi[ky, 1].f; cl  := cLgammaStpi[ky, 0].f;

  d2h := d * d;
  d2l := pcr_fma(d, d, -d2h);
  cArr := LgPairsFlat(cLgammaSinAccC, 5);
  sArr := LgPairsFlat(cLgammaSinAccS, 6);
  Pl := 0.0;
  Ph := LgPolyDD(d2h, d2l, 5, cArr, Pl);
  Ql := 0.0;
  Qh := LgPolyDD(d2h, d2l, 6, sArr, Ql);

  Ph := LgMulD(d, Ph, Pl, Pl);
  Ph := LgMul(shv, slv, Ph, Pl, Pl);
  Qh := LgMul(chv, cl, Qh, Ql, Ql);

  LgFastSum(chv, cl, Qh, Ql, Ph, Pl);
  chv := LgMulD(d, chv, cl, cl);
  LgFastSum(shv, outl, shv, slv, chv, cl);
  l := outl;
  Result := shv;
end;

// ---------------------------------------------------------------------------
// as_lgamma_asym_accurate (Stirling triple-double)
// ---------------------------------------------------------------------------
function LgAsymAcc(xh: Double; var xl_: Double; out e_: Double): Double;
var
  l0, l1, l2, l0x, l1x, l2x, l0xl, l1xl: Double;
  zh, dz, zl, dl1, dl2, wh, wl: Double;
  z2h, z2l, fh, fl: Double;
  t: Tb64u64;
  cArr: TLgFlatArr;
  ux: Double;
  k: Int32;
begin
  ux := xl_;
  l0 := LgLogdAcc(xh, l1, l2);
  if xh < cLgammaP120.f then
  begin
    zh := 1.0 / xh;
    dz := ux * zh;
    zl := (pcr_fma(zh, -xh, 1.0) - dz) * zh;
    if ux <> 0.0 then
    begin
      dl1 := LgMulD(ux, zh, pcr_fma(zh, -xh, 1.0) * zh, dl2);
      dl2 := dl2 - dl1 * dl1 / 2.0;
      LgSumDD(l1, l2, l1, l2, dl1, dl2);
    end;
    t.f := xh;
    if (t.u shr 52) > UInt64($3FF + 51) then
    begin
      wh := xh; wl := ux - 0.5;
    end
    else
    begin
      wh := xh - 0.5; wl := ux;
    end;
    l0 := l0 - 1.0;
    l0x := l0 * wh; l0xl := pcr_fma(l0, wh, -l0x);
    l1x := l1 * wh; l1xl := pcr_fma(l1, wh, -l1x);
    l2x := l2 * wh;
    LgSumDD(l1x, l2x, l1x, l2x, l0xl, l1xl);
    LgSumDD(l1x, l2x, l1x, l2x, l0 * wl, l1 * wl);
    z2h := LgMul(zh, zl, zh, zl, z2l);
    if xh >= 48.0 then
    begin
      LgSumDD(l1x, l2x, l1x, l2x, cLgammaAsy48C[0, 0].f, cLgammaAsy48C[0, 1].f);
      fl := 0.0;
      SetLength(cArr, 7 * 2);
      for k := 0 to 6 do
      begin
        cArr[2*k]   := cLgammaAsy48C[k+1, 0];
        cArr[2*k+1] := cLgammaAsy48C[k+1, 1];
      end;
      fh := LgPolyDD(z2h, z2l, 7, cArr, fl);
    end
    else if xh >= 14.5 then
    begin
      LgSumDD(l1x, l2x, l1x, l2x, cLgammaAsy14C[0, 0].f, cLgammaAsy14C[0, 1].f);
      fl := 0.0;
      SetLength(cArr, 11 * 2);
      for k := 0 to 10 do
      begin
        cArr[2*k]   := cLgammaAsy14C[k+1, 0];
        cArr[2*k+1] := cLgammaAsy14C[k+1, 1];
      end;
      fh := LgPolyDD(z2h, z2l, 11, cArr, fl);
    end
    else
    begin
      LgSumDD(l1x, l2x, l1x, l2x, cLgammaAsy4C[0, 0].f, cLgammaAsy4C[0, 1].f);
      fl := 0.0;
      SetLength(cArr, 27 * 2);
      for k := 0 to 26 do
      begin
        cArr[2*k]   := cLgammaAsy4C[k+1, 0];
        cArr[2*k+1] := cLgammaAsy4C[k+1, 1];
      end;
      fh := LgPolyDD(z2h, z2l, 27, cArr, fl);
    end;
    fh := LgMul(zh, zl, fh, fl, fl);
    LgSumDD(l1x, l2x, l1x, l2x, fh, fl);
    LgFastTwoSum(l0x, l1x, l0x, l1x);
    LgFastTwoSum(l1x, l2x, l1x, l2x);
  end
  else
  begin
    wl := ux - 0.5;
    l0 := l0 - 1.0;
    l0x := l0 * xh; l0xl := pcr_fma(l0, xh, -l0x);
    l1x := l1 * xh; l1xl := pcr_fma(l1, xh, -l1x);
    l2x := l2 * xh;
    LgSumDD(l1x, l2x, l1x, l2x, l0xl, l1xl);
    LgSumDD(l1x, l2x, l1x, l2x, l0 * wl, l1 * wl);
  end;
  xl_ := l1x;
  e_ := l2x;
  Result := l0x;
end;

// ---------------------------------------------------------------------------
// Database lookup
// ---------------------------------------------------------------------------
function LgDatabase(x, f: Double): Double;
var a, b, m: Int32;
begin
  a := 0; b := High(cLgammaDB); m := (a + b) shr 1;
  while a <= b do
  begin
    if cLgammaDB[m, 0].f < x then a := m + 1
    else if cLgammaDB[m, 0].f = x then
    begin
      f := cLgammaDB[m, 1].f + cLgammaDB[m, 2].f;
      Break;
    end
    else b := m - 1;
    m := (a + b) shr 1;
  end;
  Result := f;
end;

// ---------------------------------------------------------------------------
// Generic accurate-path branch evaluator.
// fh = muldd(zh,zl, polydd(sh,sl, n-k, c, fl=sh*polyd(sh,k,c+n-k)), fl)
// ---------------------------------------------------------------------------
procedure LgAccBranch(sx: Double;
                     const x0: array of Tb64u64;
                     const c: array of Tb64u64;
                     n, k: Int32; sc: Double;
                     out fh, fl: Double);
var
  zh, zl, sh, sl, t1: Double;
  cTopFlat: array of Double;
  i: Int32;
begin
  LgFastTwoSum(zh, zl, x0[0].f + sx, x0[1].f);
  zl := zl + x0[2].f;
  sh := zh * sc;
  sl := zl * sc;
  SetLength(cTopFlat, k);
  for i := 0 to k - 1 do cTopFlat[i] := c[2 * (n - k + i)].f;
  t1 := LgPolyDFlat(sh, k, cTopFlat);
  fl := sh * t1;
  fh := LgPolyDD(sh, sl, n - k, c, fl);
  fh := LgMul(zh, zl, fh, fl, fl);
end;

// ---------------------------------------------------------------------------
// as_lgamma_accurate
// ---------------------------------------------------------------------------
function LgAccurate(x: Double): Double;
var
  sx, fh, fl, fll, lh, ll, lll, l1h, l1l, l1ll, l2h, l2l, l2ll: Double;
  e, dfl, ax, phi, sl, sh, tmp, axTmp, flTmp: Double;
  cArrAccC0, cArrAccB, cFlatBr: TLgFlatArr;
  tl: Tb64u64;
  ft: UInt64;
begin
  sx := x;
  ax := Abs(x);
  fl := 0.0; fll := 0.0; fh := 0.0;

  cArrAccC0 := LgPairsFlat(cLgammaAccC0, 34);
  cArrAccB  := LgPairsFlat(cLgammaAccB, 30);

  if ax < cLgammaP100.f then
  begin
    lh := LgLogdAcc(ax, ll, lll);
    fh := -lh; fl := -ll; fll := -lll;
    LgFastTwoSum(fh, fl, fh, fl);
    LgFastTwoSum(fl, fll, fl, fll);
    LgFastTwoSum(tmp, e, fh, 2.0 * fl);
    if e = 0.0 then
      fl := fl * (1.0 + LgCopySignSign(fl) * cLgammaP52.f * LgCopySignSign(fll));
  end
  else if ax < 0.25 then
  begin
    fh := LgPolyDDD(sx, 34, cArrAccC0, fl);
    fh := LgMulD(sx, fh, fl, fl);
    lh := LgLogdAcc(ax, ll, lll);
    LgSumDD(fh, fl, fh, fl, -ll, -lll);
    LgTwoSum(fh, fll, -lh, fh);
    LgTwoSum(fl, fll, fll, fl);
    LgFastTwoSum(tmp, e, fh, 2.0 * fl);
    if e = 0.0 then
      fl := fl * (1.0 + LgCopySignSign(fl) * cLgammaP52.f * LgCopySignSign(fll));
  end
  else
  begin
    if Abs(ax - 0.5) < 0.25 then
    begin
      fh := LgPolyDDD(ax - 0.5, 30, cArrAccB, fl);
      if sx > 0.0 then
      begin
        lh := LgLogdAcc(ax, ll, lll);
        LgSumDD(fl, fll, fl, 0.0, -ll, -lll);
        LgTwoSum(fh, lh, fh, -lh);
        LgSumDD(fl, fll, fl, fll, lh, 0.0);
      end;
    end
    else if Abs(ax - 2.5) < 0.25 then
    begin
      fh := LgPolyDDD(ax - 2.5, 30, cArrAccB, fl);
      lh := LgLogdAcc(ax - 1.0, ll, lll);
      LgSumDD(fl, fll, fl, 0.0, ll, lll);
      LgTwoSum(fh, lh, fh, lh);
      LgSumDD(fl, fll, fl, fll, lh, 0.0);
      if sx < 0.0 then
      begin
        lh := LgLogdAcc(ax, ll, lll);
        LgSumDD(fl, fll, fl, fll, ll, lll);
        LgTwoSum(fh, lh, fh, lh);
        LgSumDD(fl, fll, fl, fll, lh, 0.0);
      end;
    end
    else if Abs(ax - 3.5) < 0.25 then
    begin
      l2h := LgLogdAcc(ax - 2.0, l2l, l2ll);
      l1h := LgLogdAcc(ax - 1.0, l1l, l1ll);
      LgSumDD(l1l, l1ll, l1l, l1ll, l2l, l2ll);
      LgFastTwoSum(l1h, l2h, l1h, l2h);
      LgSumDD(l1l, l1ll, l1l, l1ll, l2h, 0.0);
      fh := LgPolyDDD(ax - 3.5, 30, cArrAccB, fl);
      LgSumDD(fl, fll, fl, 0.0, l1l, l1ll);
      LgTwoSum(fh, l1h, fh, l1h);
      LgSumDD(fl, fll, fl, fll, l1h, 0.0);
      if sx < 0.0 then
      begin
        lh := LgLogdAcc(ax, ll, lll);
        LgSumDD(fl, fll, fl, fll, ll, lll);
        LgTwoSum(fh, lh, fh, lh);
        LgSumDD(fl, fll, fl, fll, lh, 0.0);
      end;
    end
    else if Abs(ax - 1.0) < 0.25 then
    begin
      fh := LgPolyDDD(ax - 1.0, 34, cArrAccC0, fl);
      fh := LgMulD(ax - 1.0, fh, fl, fl);
      if sx < 0.0 then
      begin
        lh := LgLogdAcc(ax, ll, lll);
        LgSumDD(fl, fll, fl, 0.0, ll, lll);
        LgTwoSum(fh, lh, fh, lh);
        LgSumDD(fl, fll, fl, fll, lh, 0.0);
      end;
    end
    else if Abs(ax - 1.5) < 0.25 then
    begin
      fh := LgPolyDDD(ax - 1.5, 30, cArrAccB, fl);
      if sx < 0.0 then
      begin
        lh := LgLogdAcc(ax, ll, lll);
        LgSumDD(fl, fll, fl, 0.0, ll, lll);
        LgTwoSum(fh, lh, fh, lh);
        LgSumDD(fl, fll, fl, fll, lh, 0.0);
      end;
    end
    else if Abs(ax - 2.0) < 0.25 then
    begin
      lh := LgLogdAcc(ax - 1.0, ll, lll);
      fh := LgPolyDDD(ax - 2.0, 34, cArrAccC0, fl);
      fh := LgMulD(ax - 2.0, fh, fl, fl);
      LgSumDD(fl, fll, fl, 0.0, ll, lll);
      LgTwoSum(fh, lh, fh, lh);
      LgSumDD(fl, fll, fl, fll, lh, 0.0);
      if sx < 0.0 then
      begin
        lh := LgLogdAcc(ax, ll, lll);
        LgSumDD(fl, fll, fl, fll, ll, lll);
        LgTwoSum(fh, lh, fh, lh);
        LgSumDD(fl, fll, fl, fll, lh, 0.0);
      end;
    end
    else if Abs(ax - 3.0) < 0.25 then
    begin
      l2h := LgLogdAcc(ax - 2.0, l2l, l2ll);
      l1h := LgLogdAcc(ax - 1.0, l1l, l1ll);
      LgSumDD(l1l, l1ll, l1l, l1ll, l2l, l2ll);
      LgFastTwoSum(l1h, l2h, l1h, l2h);
      LgSumDD(l1l, l1ll, l1l, l1ll, l2h, 0.0);
      fh := LgPolyDDD(ax - 3.0, 34, cArrAccC0, fl);
      fh := LgMulD(ax - 3.0, fh, fl, fl);
      LgSumDD(fl, fll, fl, 0.0, l1l, l1ll);
      LgTwoSum(fh, l1h, fh, l1h);
      LgSumDD(fl, fll, fl, fll, l1h, 0.0);
      if sx < 0.0 then
      begin
        lh := LgLogdAcc(ax, ll, lll);
        LgSumDD(fl, fll, fl, fll, ll, lll);
        LgTwoSum(fh, lh, fh, lh);
        LgSumDD(fl, fll, fl, fll, lh, 0.0);
      end;
    end
    else // x>3.75
    begin
      if sx < 0.0 then
      begin
        LgFastTwoSum(axTmp, flTmp, ax, 1.0);
        ax := axTmp; fl := flTmp;
      end;
      fh := LgAsymAcc(ax, fl, fll);
    end;
    if sx < 0.0 then
    begin
      if sx < -0.5 then phi := sx - LgFloor(sx) else phi := -sx;
      sh := LgSinpipidAcc(phi, sl);
      lh := LgLogdAcc(sh, ll, lll);
      ll := ll + sl / sh + lll;
      LgSumDD(fl, fll, fl, fll, ll, 0.0);
      LgTwoSum(fh, lh, fh, lh);
      LgSumDD(fl, fll, fl, fll, lh, 0.0);
      fh := -fh; fl := -fl; fll := -fll;
    end;
    LgFastTwoSum(fh, fl, fh, fl);
    LgFastTwoSum(fl, fll, fl, fll);
    LgFastTwoSum(fh, fl, fh, fl);
    LgFastTwoSum(fl, fll, fl, fll);
    LgFastTwoSum(tmp, e, fh, 2.0 * fl);
    if e = 0.0 then
    begin
      dfl := 1.0
        + LgCopySignSign(fl) * cLgammaP26.f
        * LgCopySignSign(fll) * cLgammaP26.f;
      fl := fl * dfl;
    end;
  end;

  // Accurate-path branch dispatch (17 branches), only when |fh|<0.375
  if Abs(fh) < cLgammaThrFh1.f then
  begin
    if      (Abs(fh) < cLgammaThrBr0.f) and (sx > cLgammaSXBnd.f) and (sx < -2.0) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr0C, 26);
      LgAccBranch(sx, cLgammaAccBr0X0, cFlatBr, cLgammaAccBr0N, cLgammaAccBr0K, cLgammaAccBr0Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr1.f) and (sx > -3.0) and (sx < cLgammaSXBnd.f) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr1C, 27);
      LgAccBranch(sx, cLgammaAccBr1X0, cFlatBr, cLgammaAccBr1N, cLgammaAccBr1K, cLgammaAccBr1Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr2.f) and (sx > -3.5) and (sx < -3.0) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr2C, 20);
      LgAccBranch(sx, cLgammaAccBr2X0, cFlatBr, cLgammaAccBr2N, cLgammaAccBr2K, cLgammaAccBr2Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr3.f) and (sx > -4.0) and (sx < -3.5) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr3C, 20);
      LgAccBranch(sx, cLgammaAccBr3X0, cFlatBr, cLgammaAccBr3N, cLgammaAccBr3K, cLgammaAccBr3Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr4.f) and (sx > -4.5) and (sx < -4.0) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr4C, 24);
      LgAccBranch(sx, cLgammaAccBr4X0, cFlatBr, cLgammaAccBr4N, cLgammaAccBr4K, cLgammaAccBr4Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr5.f) and (sx > -5.0) and (sx < -4.5) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr5C, 19);
      LgAccBranch(sx, cLgammaAccBr5X0, cFlatBr, cLgammaAccBr5N, cLgammaAccBr5K, cLgammaAccBr5Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr6.f) and (sx > -5.5) and (sx < -5.0) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr6C, 19);
      LgAccBranch(sx, cLgammaAccBr6X0, cFlatBr, cLgammaAccBr6N, cLgammaAccBr6K, cLgammaAccBr6Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr7.f) and (sx > -6.0) and (sx < -5.5) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr7C, 24);
      LgAccBranch(sx, cLgammaAccBr7X0, cFlatBr, cLgammaAccBr7N, cLgammaAccBr7K, cLgammaAccBr7Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr8.f) and (sx > -6.5) and (sx < -6.0) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr8C, 24);
      LgAccBranch(sx, cLgammaAccBr8X0, cFlatBr, cLgammaAccBr8N, cLgammaAccBr8K, cLgammaAccBr8Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr9.f) and (sx > -7.0) and (sx < -6.5) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr9C, 25);
      LgAccBranch(sx, cLgammaAccBr9X0, cFlatBr, cLgammaAccBr9N, cLgammaAccBr9K, cLgammaAccBr9Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr10.f) and (sx > -7.5) and (sx < -7.0) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr10C, 24);
      LgAccBranch(sx, cLgammaAccBr10X0, cFlatBr, cLgammaAccBr10N, cLgammaAccBr10K, cLgammaAccBr10Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr11.f) and (sx > -8.0) and (sx < -7.5) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr11C, 27);
      LgAccBranch(sx, cLgammaAccBr11X0, cFlatBr, cLgammaAccBr11N, cLgammaAccBr11K, cLgammaAccBr11Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr12.f) and (sx > -8.5) and (sx < -8.0) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr12C, 27);
      LgAccBranch(sx, cLgammaAccBr12X0, cFlatBr, cLgammaAccBr12N, cLgammaAccBr12K, cLgammaAccBr12Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr13.f) and (sx > -9.0) and (sx < -8.5) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr13C, 28);
      LgAccBranch(sx, cLgammaAccBr13X0, cFlatBr, cLgammaAccBr13N, cLgammaAccBr13K, cLgammaAccBr13Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr13.f) and (sx > -9.5) and (sx < -9.0) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr14C, 28);
      LgAccBranch(sx, cLgammaAccBr14X0, cFlatBr, cLgammaAccBr14N, cLgammaAccBr14K, cLgammaAccBr14Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr11.f) and (sx > -10.0) and (sx < -9.5) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr15C, 27);
      LgAccBranch(sx, cLgammaAccBr15X0, cFlatBr, cLgammaAccBr15N, cLgammaAccBr15K, cLgammaAccBr15Sc.f, fh, fl);
    end
    else if (Abs(fh) < cLgammaThrBr11.f) and (sx > -10.5) and (sx < -10.0) then
    begin
      cFlatBr := LgPairsFlat(cLgammaAccBr16C, 27);
      LgAccBranch(sx, cLgammaAccBr16X0, cFlatBr, cLgammaAccBr16N, cLgammaAccBr16K, cLgammaAccBr16Sc.f, fh, fl);
    end;
  end;

  tl.f := fl;
  ft := (tl.u + 2) and (UInt64($FFFFFFFFFFFFFFFF) shr 12);
  if ft <= 2 then
  begin
    Result := LgDatabase(sx, fh + fl);
    Exit;
  end;
  Result := fh + fl;
end;

// ---------------------------------------------------------------------------
// Main entry: pcr_lgamma_pas
// ---------------------------------------------------------------------------
function pcr_lgamma_pas(x: Double): Double;
var
  t: Tb64u64;
  nx: UInt64;
  au: UInt32;
  fx, fh, fl, eps, ax, lh, ll: Double;
  ub, lb, z, z2, z4: Double;
  q0, q2, q4, q6: Double;
  ou: UInt32;
  j, i: Int32;
  xl, hlh, zh, zl, z2h, z4h, sl, sh, fhSign, flSign: Double;
  cArrTinyC0, cArrCH: TLgFlatArr;
  cArrTinyQ: array[0..7] of Double;
  jj: UInt64;
  tmpFh, tmpFl, tmpTf: Double;
begin
  t.f := x;
  nx := t.u shl 1;
  if nx >= UInt64($feaea9b24f16a34c) then
  begin
    if t.u = UInt64($7f5754d9278b51a6) then
    begin
      Result := cLgammaSpec1Lo.f - cLgammaSpecOff.f; Exit;
    end;
    if t.u = UInt64($7f5754d9278b51a7) then
    begin
      Result := cLgammaSpec1Hi.f - cLgammaSpecOff.f; Exit;
    end;
    if nx >= (UInt64($7FF) shl 53) then
    begin
      if nx = (UInt64($7FF) shl 53) then begin Result := Abs(x); Exit; end;
      Result := x + x; Exit;
    end;
    if (t.u shr 63) <> 0 then begin Result := 1.0 / 0.0; Exit; end;
    Result := cLgammaOvflPos.f * cLgammaOvflPos.f; Exit;
  end;
  fx := LgFloor(x);
  if fx = x then
  begin
    if x <= 0.0 then begin Result := 1.0 / 0.0; Exit; end;
    if (x = 1.0) or (x = 2.0) then begin Result := 0.0; Exit; end;
  end;

  au := UInt32(nx shr 38);
  fh := 0.0; fl := 0.0; eps := 0.0;
  ax := Abs(x);

  if au < cLgammaUbrd[0] then
  begin
    // |x|<0.5
    lh := LgLogd(ax, ll);
    if au < UInt32($1da0000) then
    begin
      fh := -lh;
      fl := -ll;
      eps := 1.5e-22;
    end
    else if au < UInt32($1fd0000) then
    begin
      cArrTinyC0 := LgPairsFlat(cLgammaTinyC0, 4);
      for i := 0 to 7 do cArrTinyQ[i] := cLgammaTinyQ[i].f;
      z := x; z2 := z*z; z4 := z2*z2;
      q0 := cArrTinyQ[0] + z*cArrTinyQ[1];
      q2 := cArrTinyQ[2] + z*cArrTinyQ[3];
      q4 := cArrTinyQ[4] + z*cArrTinyQ[5];
      q6 := cArrTinyQ[6] + z*cArrTinyQ[7];
      fl := z*((q0 + z2*q2) + z4*(q4 + z2*q6));
      fh := LgPolyDDD(z, 4, cArrTinyC0, fl);
      fh := LgMulD(x, fh, fl, fl);
      LgSumDD(fh, fl, -lh, -ll, fh, fl);
      eps := 1.5e-22;
    end
    else
    begin
      // 0.03125<=|x|<0.5; reduce via x+1
      LgFastTwoSum(tmpTf, xl, 1.0, t.f);
      t.f := tmpTf;
      au := UInt32(t.u shr 37);
      ou := au - cLgammaUbrd[0];
      jj := (UInt64($157ced865) - UInt64(ou) * UInt64($150d)) * UInt64(ou) + UInt64($128000000000);
      j := Int32(jj shr 45);
      if (j >= 0) and (j <= 19) and (au < cLgammaUbrd[j]) then j := j - 1;
      z := (t.f - cLgammaOffs[j].f) + xl;
      z2 := z*z; z4 := z2*z2;
      q0 := cLgammaCL[j, 0].f + z*cLgammaCL[j, 1].f;
      q2 := cLgammaCL[j, 2].f + z*cLgammaCL[j, 3].f;
      q4 := cLgammaCL[j, 4].f + z*cLgammaCL[j, 5].f;
      q6 := cLgammaCL[j, 6].f + z*cLgammaCL[j, 7].f;
      fl := z*((q0 + z2*q2) + z4*(q4 + z2*q6));
      SetLength(cArrCH, 5*2);
      for i := 0 to 4 do
      begin
        cArrCH[2*i]   := cLgammaCH[j, i, 0];
        cArrCH[2*i+1] := cLgammaCH[j, i, 1];
      end;
      fh := LgPolyDDD(z, 5, cArrCH, fl);
      if j = 4 then
      begin
        z := -x;
        fh := LgMulD(z, fh, fl, fl);
      end;
      eps := Abs(fh) * 8.3e-20;
      LgSumDD(fh, fl, -lh, -ll, fh, fl);
      eps := eps + Abs(lh) * 5e-22;
    end;
  end
  else
  begin
    // |x|>=0.5
    if au >= cLgammaUbrd[19] then
    begin
      // Stirling
      lh := LgLogd(ax, ll);
      lh := lh - 1.0;
      if au >= UInt32($2198000) then
      begin
        if au >= UInt32($3fabaa6) then
          LgFastTwoSum(lh, ll, lh, ll);
        hlh := lh * 0.5;
        lh := LgMulD(ax, lh, ll, ll);
        ll := ll - hlh;
      end
      else
      begin
        lh := LgMulD(ax - 0.5, lh, ll, ll);
      end;
      LgFastSum(lh, ll, lh, ll, cLgammaAsymC[0, 0].f, cLgammaAsymC[0, 1].f);
      if ax < cLgammaP100Pos.f then
      begin
        zh := 1.0 / ax;
        zl := pcr_fma(zh, -ax, 1.0) * zh;
        z2h := zh*zh; z4h := z2h*z2h;
        q0 := cLgammaAsymQ[0].f + z2h*cLgammaAsymQ[1].f;
        q2 := cLgammaAsymQ[2].f + z2h*cLgammaAsymQ[3].f;
        q4 := cLgammaAsymQ[4].f;
        fl := z2h * (q0 + z4h * (q2 + z4h * q4));
        LgFastTwoSum(fh, fl, cLgammaAsymC[1, 0].f, fl);
        fl := fl + cLgammaAsymC[1, 1].f;
        fh := LgMul(fh, fl, zh, zl, fl);
      end
      else
      begin
        fh := 0.0; fl := 0.0;
      end;
      LgFastSum(fh, fl, lh, ll, fh, fl);
      eps := Abs(fh) * 4.5e-20;
    end
    else
    begin
      // |x| in [0.5, 8.29541]
      ou := au - cLgammaUbrd[0];
      jj := (UInt64($157ced865) - UInt64(ou) * UInt64($150d)) * UInt64(ou) + UInt64($128000000000);
      j := Int32(jj shr 45);
      if (j >= 0) and (j <= 19) and (au < cLgammaUbrd[j]) then j := j - 1;
      z := ax - cLgammaOffs[j].f;
      z2 := z*z; z4 := z2*z2;
      q0 := cLgammaCL[j, 0].f + z*cLgammaCL[j, 1].f;
      q2 := cLgammaCL[j, 2].f + z*cLgammaCL[j, 3].f;
      q4 := cLgammaCL[j, 4].f + z*cLgammaCL[j, 5].f;
      q6 := cLgammaCL[j, 6].f + z*cLgammaCL[j, 7].f;
      fl := z*((q0 + z2*q2) + z4*(q4 + z2*q6));
      SetLength(cArrCH, 5*2);
      for i := 0 to 4 do
      begin
        cArrCH[2*i]   := cLgammaCH[j, i, 0];
        cArrCH[2*i+1] := cLgammaCH[j, i, 1];
      end;
      fh := LgPolyDDD(z, 5, cArrCH, fl);
      if j = 4 then
      begin
        z := 1.0 - ax;
        fh := LgMulD(z, fh, fl, fl);
      end;
      if j = 10 then
      begin
        z := ax - 2.0;
        fh := LgMulD(z, fh, fl, fl);
      end;
      eps := Abs(fh) * 8.3e-20 + 1e-24;
    end;
    if (t.u shr 63) <> 0 then
    begin
      sh := LgSinpipid(x - LgFloor(x), sl);
      sh := LgMulD(-x, sh, sl, sl);
      lh := LgLogd(sh, ll);
      ll := ll + sl / sh;
      LgSumDD(tmpFh, tmpFl, fh, fl, lh, ll);
      fh := -tmpFh; fl := -tmpFl;
      eps := eps + Abs(lh) * 4e-22;
    end;
  end;

  // Suppress unused warnings on locals.
  fhSign := 0.0; flSign := 0.0;
  if fhSign = flSign then ;

  ub := fh + (fl + eps);
  lb := fh + (fl - eps);
  if ub <> lb then
  begin
    Result := LgAccurate(x);
    Exit;
  end;
  Result := ub;
end;
